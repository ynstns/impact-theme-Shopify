    "custom_liquid_4nUkGi": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": false,
        "remove_horizontal_spacing": false,
        "liquid": "{% comment %} ELIORA — Accordéon infos produit {% endcomment %}\n\n<link href=\"https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap\" rel=\"stylesheet\">\n\n<style>\n  .eli-acc {\n    font-family: 'Poppins', -apple-system, BlinkMacSystemFont, sans-serif;\n    color: #1A1A1A;\n    max-width: 680px;\n    margin: 0 auto;\n    padding: 8px 0;\n  }\n  .eli-acc__item {\n    border-bottom: 1px solid rgba(26,26,26,0.10);\n  }\n  .eli-acc__head {\n    width: 100%;\n    background: none;\n    border: none;\n    cursor: pointer;\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    padding: 20px 4px;\n    text-align: left;\n    font-family: inherit;\n  }\n  .eli-acc__icon {\n    width: 38px;\n    height: 38px;\n    min-width: 38px;\n    border-radius: 50%;\n    background: rgba(201,120,91,0.12);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    flex-shrink: 0;\n  }\n  .eli-acc__icon svg {\n    width: 19px; height: 19px;\n    stroke: #C9785B; fill: none;\n    stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round;\n  }\n  .eli-acc__title {\n    flex: 1;\n    font-size: 16px;\n    font-weight: 600;\n    color: #1A1A1A;\n  }\n  .eli-acc__chevron {\n    width: 18px; height: 18px;\n    stroke: #C9785B; fill: none;\n    stroke-width: 2.2; stroke-linecap: round; stroke-linejoin: round;\n    flex-shrink: 0;\n    transition: transform 0.3s ease;\n  }\n  .eli-acc__item.is-open .eli-acc__chevron {\n    transform: rotate(180deg);\n  }\n  .eli-acc__body {\n    max-height: 0;\n    overflow: hidden;\n    transition: max-height 0.4s ease;\n  }\n  .eli-acc__body-inner {\n    padding: 0 4px 22px 66px;\n    font-size: 14.5px;\n    line-height: 1.65;\n    color: #5A554E;\n  }\n  .eli-acc__body-inner strong { color: #1A1A1A; font-weight: 600; }\n  .eli-acc__body-inner ul {\n    margin: 0; padding: 0; list-style: none;\n  }\n  .eli-acc__body-inner li {\n    position: relative;\n    padding-left: 20px;\n    margin-bottom: 10px;\n  }\n  .eli-acc__body-inner li::before {\n    content: \"\";\n    position: absolute;\n    left: 0; top: 8px;\n    width: 7px; height: 7px;\n    border-radius: 50%;\n    background: #E0A23C;\n  }\n  .eli-acc__ingr-name { color: #1A1A1A; font-weight: 600; }\n  .eli-acc__sub {\n    font-size: 14px;\n    font-weight: 600;\n    color: #1A1A1A;\n    margin: 18px 0 8px;\n  }\n  .eli-acc__sub:first-child { margin-top: 0; }\n\n  @media (max-width: 600px) {\n    .eli-acc__title { font-size: 15px; }\n    .eli-acc__body-inner {\n      padding-left: 16px;\n      font-size: 13.5px;\n    }\n    .eli-acc__head { gap: 12px; padding: 18px 2px; }\n  }\n</style>\n\n<div class=\"eli-acc\">\n\n  <!-- DESCRIPTION -->\n  <div class=\"eli-acc__item is-open\">\n    <button class=\"eli-acc__head\" type=\"button\">\n      <span class=\"eli-acc__icon\"><svg viewBox=\"0 0 24 24\"><path d=\"M4 19.5A2.5 2.5 0 0 1 6.5 17H20\"/><path d=\"M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z\"/></svg></span>\n      <span class=\"eli-acc__title\">Description</span>\n      <svg class=\"eli-acc__chevron\" viewBox=\"0 0 24 24\"><polyline points=\"6 9 12 15 18 9\"/></svg>\n    </button>\n    <div class=\"eli-acc__body\">\n      <div class=\"eli-acc__body-inner\">\n        <p>Le ventre qui gonfle après les repas, l'inconfort en fin de journée, le jean qu'on déboutonne… <strong>Eliora</strong> est une cure naturelle pensée pour retrouver un <strong>ventre léger</strong> et un vrai confort digestif au quotidien.</p>\n        <p>Sa formule à base de <strong>charbon végétal actif</strong>, de fenouil et de gingembre aide à réduire les ballonnements et à apaiser la digestion — en douceur, sans effet laxatif. Fabriquée en France.</p>\n      </div>\n    </div>\n  </div>\n\n  <!-- INGRÉDIENTS -->\n  <div class=\"eli-acc__item\">\n    <button class=\"eli-acc__head\" type=\"button\">\n      <span class=\"eli-acc__icon\"><svg viewBox=\"0 0 24 24\"><path d=\"M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z\"/><path d=\"M2 21c0-3 1.85-5.36 5.08-6\"/></svg></span>\n      <span class=\"eli-acc__title\">Ingrédients</span>\n      <svg class=\"eli-acc__chevron\" viewBox=\"0 0 24 24\"><polyline points=\"6 9 12 15 18 9\"/></svg>\n    </button>\n    <div class=\"eli-acc__body\">\n      <div class=\"eli-acc__body-inner\">\n        <ul>\n          <li><span class=\"eli-acc__ingr-name\">Charbon végétal actif</span> — contribue à réduire les flatulences excessives après le repas.</li>\n          <li><span class=\"eli-acc__ingr-name\">Fenouil</span> — traditionnellement reconnu pour soutenir le confort digestif.</li>\n          <li><span class=\"eli-acc__ingr-name\">Gingembre</span> — aide à apaiser la digestion après les repas.</li>\n        </ul>\n        <p style=\"margin-top:14px;\">Gélule végétale. Sans hormones, sans accoutumance. Fabriqué en France.</p>\n      </div>\n    </div>\n  </div>\n\n  <!-- COMMENT L'UTILISER -->\n  <div class=\"eli-acc__item\">\n    <button class=\"eli-acc__head\" type=\"button\">\n      <span class=\"eli-acc__icon\"><svg viewBox=\"0 0 24 24\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><polyline points=\"12 6 12 12 16 14\"/></svg></span>\n      <span class=\"eli-acc__title\">Comment l'utiliser</span>\n      <svg class=\"eli-acc__chevron\" viewBox=\"0 0 24 24\"><polyline points=\"6 9 12 15 18 9\"/></svg>\n    </button>\n    <div class=\"eli-acc__body\">\n      <div class=\"eli-acc__body-inner\">\n        <ul>\n          <li><strong>2 gélules par jour</strong>, avec un grand verre d'eau.</li>\n          <li>De préférence <strong>avant le repas principal</strong>, midi ou soir.</li>\n          <li>En <strong>cure de 1 à 3 mois</strong> pour des résultats durables — la régularité est la clé.</li>\n        </ul>\n        <p style=\"margin-top:14px;\">Déconseillé aux femmes enceintes ou allaitantes. Ne se substitue pas à une alimentation variée et équilibrée.</p>\n      </div>\n    </div>\n  </div>\n\n  <!-- POURQUOI ELIORA -->\n  <div class=\"eli-acc__item\">\n    <button class=\"eli-acc__head\" type=\"button\">\n      <span class=\"eli-acc__icon\"><svg viewBox=\"0 0 24 24\"><path d=\"M12 2l2.4 7.4H22l-6 4.6 2.3 7.4-6.3-4.6L5.7 21.4 8 14 2 9.4h7.6z\"/></svg></span>\n      <span class=\"eli-acc__title\">Pourquoi Eliora</span>\n      <svg class=\"eli-acc__chevron\" viewBox=\"0 0 24 24\"><polyline points=\"6 9 12 15 18 9\"/></svg>\n    </button>\n    <div class=\"eli-acc__body\">\n      <div class=\"eli-acc__body-inner\">\n        <ul>\n          <li><strong>100% naturel</strong> — charbon végétal, fenouil & gingembre.</li>\n          <li><strong>Doux</strong> — sans effet laxatif, sans accoutumance.</li>\n          <li><strong>Fabriqué en France</strong> — formule contrôlée, qualité tracée.</li>\n          <li><strong>Pensé pour les femmes</strong> — un confort digestif au quotidien.</li>\n        </ul>\n      </div>\n    </div>\n  </div>\n\n  <!-- LIVRAISON & GARANTIE -->\n  <div class=\"eli-acc__item\">\n    <button class=\"eli-acc__head\" type=\"button\">\n      <span class=\"eli-acc__icon\"><svg viewBox=\"0 0 24 24\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/><path d=\"M9 12l2 2 4-4\"/></svg></span>\n      <span class=\"eli-acc__title\">Livraison & garantie</span>\n      <svg class=\"eli-acc__chevron\" viewBox=\"0 0 24 24\"><polyline points=\"6 9 12 15 18 9\"/></svg>\n    </button>\n    <div class=\"eli-acc__body\">\n      <div class=\"eli-acc__body-inner\">\n        <p class=\"eli-acc__sub\">Livraison offerte dès 2 flacons</p>\n        <p>Expédition sous 24–48h depuis la France.</p>\n        <p class=\"eli-acc__sub\">Garantie 90 jours satisfaite ou remboursée</p>\n        <p>Si vous ne constatez pas de résultats, nous vous remboursons intégralement — sans question.</p>\n      </div>\n    </div>\n  </div>\n\n</div>\n\n<script>\n  (function() {\n    var items = document.querySelectorAll('.eli-acc__item');\n    function setH(item) {\n      var body = item.querySelector('.eli-acc__body');\n      if (item.classList.contains('is-open')) {\n        body.style.maxHeight = body.scrollHeight + 'px';\n      } else {\n        body.style.maxHeight = '0px';\n      }\n    }\n    items.forEach(function(item) {\n      setH(item);\n      item.querySelector('.eli-acc__head').addEventListener('click', function() {\n        var wasOpen = item.classList.contains('is-open');\n        items.forEach(function(i) { i.classList.remove('is-open'); setH(i); });\n        if (!wasOpen) { item.classList.add('is-open'); setH(item); }\n      });\n    });\n    window.addEventListener('resize', function() {\n      items.forEach(setH);\n    });\n  })();\n</script>",
