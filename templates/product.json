15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg>\n      <svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg>\n      <svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg>\n      <svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg>\n    </span>\n    <span class=\"eli-hero__rating-note\">Noté 4.8 <em>Excellent</em></span>\n    <span class=\"eli-hero__rating-sep\">·</span>\n    <span class=\"eli-hero__rating-count\">+10 000 avis vérifiés</span>\n  </div>\n\n  <p class=\"eli-hero__eyebrow\">87% de nos clientes observent</p>\n  <h2 class=\"eli-hero__title\">Un ventre plus léger <em>en 21 jours.</em></h2>\n  <div class=\"eli-hero__divider\"></div>\n\n  <div class=\"eli-hero__benefits\">\n\n    <div class=\"eli-hero__benefit\">\n      <div class=\"eli-hero__benefit-icon\">\n        <svg viewBox=\"0 0 24 24\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/><path d=\"M9 12l2 2 4-4\"/></svg>\n      </div>\n      <div class=\"eli-hero__benefit-body\">\n        <p class=\"eli-hero__benefit-title\">Réduit les ballonnements</p>\n        <p class=\"eli-hero__benefit-text\">Dès les premiers jours de cure</p>\n      </div>\n    </div>\n\n    <div class=\"eli-hero__benefit\">\n      <div class=\"eli-hero__benefit-icon\">\n        <svg viewBox=\"0 0 24 24\"><path d=\"M3 12h4l3 8 4-16 3 8h4\"/></svg>\n      </div>\n      <div class=\"eli-hero__benefit-body\">\n        <p class=\"eli-hero__benefit-title\">Confort digestif</p>\n        <p class=\"eli-hero__benefit-text\">Un ventre apaisé après les repas</p>\n      </div>\n    </div>\n\n    <div class=\"eli-hero__benefit\">\n      <div class=\"eli-hero__benefit-icon\">\n        <svg viewBox=\"0 0 24 24\"><path d=\"M21 2v6h-6\"/><path d=\"M3 12a9 9 0 0 1 15-6.7L21 8\"/><path d=\"M3 22v-6h6\"/><path d=\"M21 12a9 9 0 0 1-15 6.7L3 16\"/></svg>\n      </div>\n      <div class=\"eli-hero__benefit-body\">\n        <p class=\"eli-hero__benefit-title\">Sans accoutumance</p>\n        <p class=\"eli-hero__benefit-text\">Doux, sans effet laxatif</p>\n      </div>\n    </div>\n\n    <div class=\"eli-hero__benefit\">\n      <div class=\"eli-hero__benefit-icon\">\n        <svg viewBox=\"0 0 24 24\"><path d=\"M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z\"/><path d=\"M2 21c0-3 1.85-5.36 5.08-6\"/></svg>\n      </div>\n      <div class=\"eli-hero__benefit-body\">\n        <p class=\"eli-hero__benefit-title\">100% naturel</p>\n        <p class=\"eli-hero__benefit-text\">Charbon végétal, fenouil & gingembre</p>\n      </div>\n    </div>\n\n  </div>\n\n  <div class=\"eli-hero__stock\">\n    <div class=\"eli-hero__stock-track\">\n      <div class=\"eli-hero__stock-fill\" id=\"eliStockFill\"></div>\n    </div>\n    <span class=\"eli-hero__stock-label\">93% <span>VENDU</span></span>\n  </div>\n\n</div>\n\n<script>\n  (function() {\n    var fill = document.getElementById('eliStockFill');\n    if (!fill) return;\n    function go() { fill.classList.add('is-filled'); }\n    if ('IntersectionObserver' in window) {\n      var obs = new IntersectionObserver(function(entries) {\n        entries.forEach(function(e) {\n          if (e.isIntersecting) { go(); obs.disconnect(); }\n        });\n      }, { threshold: 0.4 });\n      obs.observe(fill);\n    } else { setTimeout(go, 300); }\n  })();\n</script>"
