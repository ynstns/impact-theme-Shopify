        "liquid_yH34MH": {
          "type": "liquid",
          "settings": {
            "liquid": "{% comment %} ELIORA — Bloc héro produit (note + bénéfices + barre stock) {% endcomment %}\n\n<link href=\"https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,400;0,500;0,600;0,700;1,500&display=swap\" rel=\"stylesheet\">\n\n<style>\n  .eli-hero {\n    font-family: 'Poppins', -apple-system, BlinkMacSystemFont, sans-serif;\n    color: #1A1A1A;\n    max-width: 640px;\n    margin: 0 auto;\n    padding: 8px 4px;\n  }\n\n  /* Note / avis — sur une seule ligne */\n  .eli-hero__rating {\n    display: flex;\n    align-items: center;\n    flex-wrap: nowrap;\n    gap: 7px;\n    white-space: nowrap;\n    font-size: clamp(12px, 3.4vw, 16px);\n    margin-bottom: 14px;\n    overflow: hidden;\n  }\n  .eli-hero__stars { display: inline-flex; gap: 2px; flex-shrink: 0; }\n  .eli-hero__stars svg { width: 1.05em; height: 1.05em; fill: #C9785B; }\n  .eli-hero__rating-note { font-weight: 600; flex-shrink: 0; }\n  .eli-hero__rating-note em { font-style: italic; font-weight: 500; }\n  .eli-hero__rating-sep { color: #C9785B; flex-shrink: 0; }\n  .eli-hero__rating-count { font-weight: 600; flex-shrink: 0; }\n\n  /* Suraccroche */\n  .eli-hero__eyebrow {\n    font-size: 13px;\n    font-weight: 600;\n    letter-spacing: 0.18em;\n    text-transform: uppercase;\n    color: #9C4F36;\n    margin-bottom: 8px;\n  }\n\n  /* Titre */\n  .eli-hero__title {\n    font-size: clamp(30px, 6vw, 46px);\n    font-weight: 600;\n    line-height: 1.08;\n    letter-spacing: -0.02em;\n    margin: 0 0 14px;\n    color: #1A1A1A;\n  }\n  .eli-hero__title em {\n    font-style: italic;\n    font-weight: 500;\n    color: #C9785B;\n  }\n\n  .eli-hero__divider {\n    width: 70px;\n    height: 3px;\n    background: #C9785B;\n    border-radius: 2px;\n    margin-bottom: 26px;\n  }\n\n  /* Grille bénéfices */\n  .eli-hero__benefits {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 22px 26px;\n    margin-bottom: 30px;\n  }\n  .eli-hero__benefit {\n    display: flex;\n    align-items: flex-start;\n    gap: 14px;\n    min-width: 0;\n  }\n  .eli-hero__benefit-icon {\n    width: 46px;\n    height: 46px;\n    min-width: 46px;\n    border-radius: 50%;\n    background: rgba(201, 120, 91, 0.12);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    flex-shrink: 0;\n  }\n  .eli-hero__benefit-icon svg {\n    width: 22px;\n    height: 22px;\n    stroke: #C9785B;\n    fill: none;\n    stroke-width: 1.8;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n  .eli-hero__benefit-body { min-width: 0; }\n  .eli-hero__benefit-title {\n    font-size: clamp(14px, 2vw, 18px);\n    font-weight: 600;\n    line-height: 1.2;\n    margin: 0 0 4px;\n    color: #1A1A1A;\n  }\n  .eli-hero__benefit-text {\n    font-size: 14px;\n    font-weight: 400;\n    line-height: 1.35;\n    color: #8A8178;\n    margin: 0;\n  }\n\n  /* Barre de stock */\n  .eli-hero__stock {\n    background: #FFFFFF;\n    border: 1px solid rgba(26,26,26,0.06);\n    border-radius: 16px;\n    padding: 20px 24px;\n    display: flex;\n    align-items: center;\n    gap: 18px;\n    box-shadow: 0 6px 20px rgba(26,26,26,0.04);\n  }\n  .eli-hero__stock-track {\n    flex: 1;\n    height: 14px;\n    background: #EDE6DC;\n    border-radius: 20px;\n    overflow: hidden;\n  }\n  .eli-hero__stock-fill {\n    height: 100%;\n    width: 0;\n    background: linear-gradient(90deg, #9E2A24 0%, #C0392B 100%);\n    border-radius: 20px;\n    transition: width 1.6s cubic-bezier(0.22, 1, 0.36, 1);\n  }\n  .eli-hero__stock-fill.is-filled { width: 93%; }\n  .eli-hero__stock-label {\n    font-size: 22px;\n    font-weight: 700;\n    color: #C0392B;\n    white-space: nowrap;\n    flex-shrink: 0;\n    letter-spacing: -0.01em;\n  }\n  .eli-hero__stock-label span {\n    font-size: 13px;\n    font-weight: 600;\n    color: #8A8178;\n    letter-spacing: 0.08em;\n    margin-left: 4px;\n  }\n\n  /* MOBILE — version compressée, icônes réduites, fix overflow avis */\n  @media (max-width: 600px) {\n    .eli-hero { padding: 4px 2px; }\n\n    .eli-hero__rating {\n      font-size: clamp(12px, 3.6vw, 14px);\n      gap: 5px;\n      margin-bottom: 8px;\n    }\n    .eli-hero__eyebrow { font-size: 10.5px; margin-bottom: 5px; }\n    .eli-hero__title { font-size: clamp(24px, 7.5vw, 34px); margin: 0 0 8px; }\n    .eli-hero__divider { margin-bottom: 14px; }\n\n    .eli-hero__benefits {\n      grid-template-columns: 1fr 1fr;\n      gap: 16px 10px;\n      margin-bottom: 16px;\n    }\n    .eli-hero__benefit { gap: 8px; }\n    .eli-hero__benefit-icon { width: 28px; height: 28px; min-width: 28px; }\n    .eli-hero__benefit-icon svg { width: 13px; height: 13px; stroke-width: 2; }\n    .eli-hero__benefit-title { font-size: 13px; margin: 0 0 2px; }\n    .eli-hero__benefit-text { font-size: 11.5px; }\n\n    .eli-hero__stock { padding: 12px 14px; gap: 10px; border-radius: 12px; }\n    .eli-hero__stock-track { height: 10px; }\n    .eli-hero__stock-label { font-size: 16px; }\n    .eli-hero__stock-label span { font-size: 10px; }\n  }\n\n  @media (max-width: 380px) {\n    .eli-hero__rating { font-size: 11px; gap: 4px; }\n  }\n\n  @media (prefers-reduced-motion: reduce) {\n    .eli-hero__stock-fill { transition: none; }\n  }\n</style>\n\n<div class=\"eli-hero\">\n\n  <!-- Note + avis (une seule ligne) -->\n  <div class=\"eli-hero__rating\">\n    <span class=\"eli-hero__stars\">\n      <svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg>\n      <svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg>\n      <svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg>\n      <svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg>\n      <svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg>\n    </span>\n    <span class=\"eli-hero__rating-note\">Noté 4.8 <em>Excellent</em></span>\n    <span class=\"eli-hero__rating-sep\">·</span>\n    <span class=\"eli-hero__rating-count\">+10 000 avis vérifiés</span>\n  </div>\n\n  <p class=\"eli-hero__eyebrow\">87% de nos clientes observent</p>\n  <h2 class=\"eli-hero__title\">Un ventre plus léger <em>en 14 jours.</em></h2>\n  <div class=\"eli-hero__divider\"></div>\n\n  <!-- Bénéfices -->\n  <div class=\"eli-hero__benefits\">\n\n    <div class=\"eli-hero__benefit\">\n      <div class=\"eli-hero__benefit-icon\">\n        <svg viewBox=\"0 0 24 24\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/><path d=\"M9 12l2 2 4-4\"/></svg>\n      </div>\n      <div class=\"eli-hero__benefit-body\">\n        <p class=\"eli-hero__benefit-title\">Réduit les ballonnements</p>\n        <p class=\"eli-hero__benefit-text\">Dès les premiers jours de cure</p>\n      </div>\n    </div>\n\n    <div class=\"eli-hero__benefit\">\n      <div class=\"eli-hero__benefit-icon\">\n        <svg viewBox=\"0 0 24 24\"><path d=\"M3 12h4l3 8 4-16 3 8h4\"/></svg>\n      </div>\n      <div class=\"eli-hero__benefit-body\">\n        <p class=\"eli-hero__benefit-title\">Confort digestif</p>\n        <p class=\"eli-hero__benefit-text\">Un ventre apaisé après les repas</p>\n      </div>\n    </div>\n\n    <div class=\"eli-hero__benefit\">\n      <div class=\"eli-hero__benefit-icon\">\n        <svg viewBox=\"0 0 24 24\"><path d=\"M21 2v6h-6\"/><path d=\"M3 12a9 9 0 0 1 15-6.7L21 8\"/><path d=\"M3 22v-6h6\"/><path d=\"M21 12a9 9 0 0 1-15 6.7L3 16\"/></svg>\n      </div>\n      <div class=\"eli-hero__benefit-body\">\n        <p class=\"eli-hero__benefit-title\">Sans accoutumance</p>\n        <p class=\"eli-hero__benefit-text\">Doux, sans effet laxatif</p>\n      </div>\n    </div>\n\n    <div class=\"eli-hero__benefit\">\n      <div class=\"eli-hero__benefit-icon\">\n        <svg viewBox=\"0 0 24 24\"><path d=\"M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z\"/><path d=\"M2 21c0-3 1.85-5.36 5.08-6\"/></svg>\n      </div>\n      <div class=\"eli-hero__benefit-body\">\n        <p class=\"eli-hero__benefit-title\">100% naturel</p>\n        <p class=\"eli-hero__benefit-text\">Charbon végétal, fenouil & gingembre</p>\n      </div>\n    </div>\n\n  </div>\n\n  <!-- Barre de stock -->\n  <div class=\"eli-hero__stock\">\n    <div class=\"eli-hero__stock-track\">\n      <div class=\"eli-hero__stock-fill\" id=\"eliStockFill\"></div>\n    </div>\n    <span class=\"eli-hero__stock-label\">93% <span>VENDU</span></span>\n  </div>\n\n</div>\n\n<script>\n  (function() {\n    var fill = document.getElementById('eliStockFill');\n    if (!fill) return;\n    function go() { fill.classList.add('is-filled'); }\n    if ('IntersectionObserver' in window) {\n      var obs = new IntersectionObserver(function(entries) {\n        entries.forEach(function(e) {\n          if (e.isIntersecting) { go(); obs.disconnect(); }\n        });\n      }, { threshold: 0.4 });\n      obs.observe(fill);\n    } else { setTimeout(go, 300); }\n  })();\n</script>"
