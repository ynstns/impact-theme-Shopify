        "liquid": "{% comment %} ELIORA — Hero banner compact {% endcomment %}\n\n<link href=\"https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&display=swap\" rel=\"stylesheet\">\n\n<style>\n  .eli-hero-banner {\n    position: relative;\n    width: 100vw;\n    margin-left: 50%;\n    transform: translateX(-50%);\n    height: 70vh;\n    min-height: 480px;\n    max-height: 640px;\n    display: flex;\n    align-items: flex-end;\n    overflow: hidden;\n    background: #1A1A1A;\n    font-family: 'Poppins', sans-serif;\n  }\n\n  .eli-hero-banner__bg {\n    position: absolute;\n    inset: 0;\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    object-position: center 15%;\n  }\n\n  .eli-hero-banner__overlay {\n    position: absolute;\n    inset: 0;\n    background: linear-gradient(\n      to top,\n      rgba(26,26,26,0.65) 0%,\n      rgba(26,26,26,0.25) 45%,\n      rgba(26,26,26,0.00) 100%\n    );\n    z-index: 1;\n  }\n\n  .eli-hero-banner__content {\n    position: relative;\n    z-index: 2;\n    width: 100%;\n    max-width: 560px;\n    padding: 0 48px 40px 56px;\n    display: flex;\n    flex-direction: column;\n  }\n\n  .eli-hero-banner__eyebrow {\n    font-size: 9.5px;\n    font-weight: 700;\n    letter-spacing: 0.18em;\n    text-transform: uppercase;\n    color: #C9785B;\n    margin: 0 0 8px;\n  }\n\n  .eli-hero-banner__title {\n    font-size: clamp(24px, 3.8vw, 42px);\n    font-weight: 300;\n    line-height: 1.12;\n    letter-spacing: -0.025em;\n    color: #FFFFFF;\n    margin: 0 0 10px;\n  }\n  .eli-hero-banner__title em {\n    font-style: italic;\n    font-weight: 300;\n    color: #FAF6F0;\n  }\n  .eli-hero-banner__title strong {\n    font-weight: 600;\n    font-style: normal;\n  }\n\n  .eli-hero-banner__subtitle {\n    font-size: 12.5px;\n    font-weight: 400;\n    line-height: 1.5;\n    color: rgba(255,255,255,0.68);\n    margin: 0 0 20px;\n    max-width: 380px;\n  }\n  .eli-hero-banner__subtitle span {\n    color: rgba(255,255,255,0.92);\n    font-weight: 500;\n  }\n\n  .eli-hero-banner__cta-wrap {\n    display: flex;\n    align-items: center;\n    gap: 16px;\n    margin-bottom: 18px;\n  }\n  .eli-hero-banner__cta-btn {\n    display: inline-flex;\n    align-items: center;\n    gap: 9px;\n    background: #FAF6F0;\n    color: #1A1A1A;\n    font-family: 'Poppins', sans-serif;\n    font-size: 11px;\n    font-weight: 700;\n    letter-spacing: 0.14em;\n    text-transform: uppercase;\n    text-decoration: none;\n    padding: 13px 28px;\n    border-radius: 4px;\n    border: none;\n    cursor: pointer;\n    transition: background 0.2s, transform 0.2s;\n    white-space: nowrap;\n  }\n  .eli-hero-banner__cta-btn:hover {\n    background: #FFFFFF;\n    transform: translateY(-2px);\n  }\n  .eli-hero-banner__cta-btn svg {\n    width: 13px; height: 13px;\n    stroke: #1A1A1A; fill: none;\n    stroke-width: 2.2; stroke-linecap: round; stroke-linejoin: round;\n    transition: transform 0.2s;\n  }\n  .eli-hero-banner__cta-btn:hover svg { transform: translateX(3px); }\n\n  .eli-hero-banner__badges {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    flex-wrap: wrap;\n  }\n  .eli-hero-banner__badge {\n    display: flex;\n    align-items: center;\n    gap: 5px;\n    font-size: 10.5px;\n    font-weight: 500;\n    color: rgba(255,255,255,0.60);\n    white-space: nowrap;\n  }\n  .eli-hero-banner__badge svg {\n    width: 12px; height: 12px;\n    stroke: #C9785B; fill: none;\n    stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round;\n    flex-shrink: 0;\n  }\n  .eli-hero-banner__badge-sep {\n    width: 1px; height: 11px;\n    background: rgba(255,255,255,0.16);\n  }\n\n  @media (max-width: 768px) {\n    .eli-hero-banner {\n      height: 85svh;\n      min-height: 0;\n      max-height: none;\n      align-items: flex-end;\n    }\n    .eli-hero-banner__bg { object-position: 60% 10%; }\n    .eli-hero-banner__overlay {\n      background: linear-gradient(\n        to top,\n        rgba(26,26,26,0.70) 0%,\n        rgba(26,26,26,0.30) 50%,\n        rgba(26,26,26,0.00) 100%\n      );\n    }\n    .eli-hero-banner__content {\n      padding: 0 20px 32px;\n      max-width: 100%;\n    }\n    .eli-hero-banner__title { font-size: clamp(22px, 6.5vw, 30px); }\n    .eli-hero-banner__subtitle { font-size: 12px; margin-bottom: 16px; }\n    .eli-hero-banner__cta-btn {\n      width: 100%;\n      justify-content: center;\n      padding: 13px 20px;\n    }\n    .eli-hero-banner__cta-wrap {\n      flex-direction: column;\n      align-items: stretch;\n      margin-bottom: 14px;\n    }\n    .eli-hero-banner__badges { gap: 8px; }\n    .eli-hero-banner__badge { font-size: 10px; }\n    .eli-hero-banner__eyebrow { font-size: 9px; }\n  }\n</style>\n\n<section class=\"eli-hero-banner\">\n\n  <picture>\n    <source\n      media=\"(max-width: 768px)\"\n      srcset=\"https://cdn.shopify.com/s/files/1/0941/4010/5040/files/ChatGPT_Image_24_juin_2026_a_02_00_03.png?v=1782259501\"\n    >\n    <source\n      media=\"(min-width: 769px)\"\n      srcset=\"https://cdn.shopify.com/s/files/1/0941/4010/5040/files/ChatGPT_Image_24_juin_2026_a_02_04_23.png?v=1782259501\"\n    >\n    <img\n      class=\"eli-hero-banner__bg\"\n      src=\"https://cdn.shopify.com/s/files/1/0941/4010/5040/files/ChatGPT_Image_24_juin_2026_a_02_04_23.png?v=1782259501\"\n      alt=\"Eliora — Gélule Anti-Ballonnement\"\n      loading=\"eager\"\n      fetchpriority=\"high\"\n    >\n  </picture>\n\n  <div class=\"eli-hero-banner__overlay\"></div>\n\n  <div class=\"eli-hero-banner__content\">\n\n    <p class=\"eli-hero-banner__eyebrow\">100% naturel · Sans dépendance · Vegan & sans gluten</p>\n\n    <h1 class=\"eli-hero-banner__title\">\n      Sans ballonnements.<br>\n      <em>Sans compromis.</em><br>\n      <strong>Chaque jour.</strong>\n    </h1>\n\n    <p class=\"eli-hero-banner__subtitle\">\n      La gélule au <span>charbon végétal actif</span> qui capture les gaz\n      et apaise ta digestion — naturellement, dès le repas.\n    </p>\n\n    <div class=\"eli-hero-banner__cta-wrap\">\n      <a href=\"/products/gelule-anti-ballonnement\" class=\"eli-hero-banner__cta-btn\">\n        Je découvre ma cure\n        <svg viewBox=\"0 0 24 24\"><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/><polyline points=\"12 5 19 12 12 19\"/></svg>\n      </a>\n    </div>\n\n    <div class=\"eli-hero-banner__badges\">\n      <span class=\"eli-hero-banner__badge\">\n        <svg viewBox=\"0 0 24 24\"><path d=\"M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z\"/><path d=\"M2 21c0-3 1.85-5.36 5.08-6\"/></svg>\n        100% naturel\n      </span>\n      <span class=\"eli-hero-banner__badge-sep\"></span>\n      <span class=\"eli-hero-banner__badge\">\n        <svg viewBox=\"0 0 24 24\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/><path d=\"M9 12l2 2 4-4\"/></svg>\n        Garanti 90 jours\n      </span>\n      <span class=\"eli-hero-banner__badge-sep\"></span>\n      <span class=\"eli-hero-banner__badge\">\n        <svg viewBox=\"0 0 24 24\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><path d=\"M8 12l3 3 5-5\"/></svg>\n        Sans accoutumance\n      </span>\n    </div>\n\n  </div>\n\n</section>",
