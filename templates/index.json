        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": false,
        "liquid": "{% comment %} ELIORA — Cartes ingrédients actifs (format Oren : photo + liste à puces) {% endcomment %}\n\n<link href=\"https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,400;0,500;0,600;0,700;1,500&display=swap\" rel=\"stylesheet\">\n\n<style>\n  .eli-ing {\n    font-family: 'Poppins', -apple-system, BlinkMacSystemFont, sans-serif;\n    color: #1A1A1A;\n    max-width: 640px;\n    margin: 0 auto;\n    padding: 8px 4px;\n  }\n\n  .eli-ing__card {\n    background: #FFFFFF;\n    border: 1px solid rgba(26,26,26,0.07);\n    border-radius: 20px;\n    overflow: hidden;\n    box-shadow: 0 8px 24px rgba(26,26,26,0.05);\n    margin-bottom: 28px;\n  }\n  .eli-ing__card:last-child { margin-bottom: 0; }\n\n  .eli-ing__photo {\n    width: 100%;\n    aspect-ratio: 4 / 3;\n    object-fit: cover;\n    display: block;\n    background: #EDE6DC;\n  }\n\n  .eli-ing__body {\n    padding: 24px 26px 26px;\n  }\n\n  .eli-ing__eyebrow {\n    font-size: 12px;\n    font-weight: 700;\n    letter-spacing: 0.18em;\n    text-transform: uppercase;\n    color: #C9785B;\n    margin: 0 0 8px;\n  }\n\n  .eli-ing__title {\n    font-size: clamp(24px, 5vw, 32px);\n    font-weight: 600;\n    line-height: 1.12;\n    letter-spacing: -0.01em;\n    margin: 0 0 6px;\n    color: #1A1A1A;\n  }\n\n  .eli-ing__subtitle {\n    font-size: 14px;\n    font-style: italic;\n    font-weight: 400;\n    color: #8A8178;\n    margin: 0 0 16px;\n  }\n\n  .eli-ing__divider {\n    width: 54px;\n    height: 3px;\n    background: #C9785B;\n    border-radius: 2px;\n    margin-bottom: 18px;\n  }\n\n  .eli-ing__list {\n    list-style: none;\n    margin: 0 0 18px;\n    padding: 0;\n    display: flex;\n    flex-direction: column;\n    gap: 14px;\n  }\n  .eli-ing__list li {\n    display: flex;\n    align-items: flex-start;\n    gap: 12px;\n    font-size: 15px;\n    line-height: 1.4;\n    color: #4A4640;\n  }\n  .eli-ing__dot {\n    width: 7px;\n    height: 7px;\n    min-width: 7px;\n    border-radius: 50%;\n    background: #C9785B;\n    margin-top: 7px;\n    flex-shrink: 0;\n  }\n  .eli-ing__list strong {\n    font-weight: 600;\n    color: #1A1A1A;\n  }\n\n  .eli-ing__badge {\n    display: inline-flex;\n    align-items: center;\n    gap: 8px;\n    background: rgba(201, 120, 91, 0.10);\n    color: #9C4F36;\n    font-size: 14px;\n    font-weight: 600;\n    padding: 10px 18px;\n    border-radius: 999px;\n  }\n  .eli-ing__badge svg {\n    width: 16px;\n    height: 16px;\n    stroke: #9C4F36;\n    fill: none;\n    stroke-width: 2.5;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n    flex-shrink: 0;\n  }\n\n  /* Accroche + CTA */\n  .eli-ing__cta-wrap {\n    text-align: center;\n    margin-top: 32px;\n  }\n  .eli-ing__cta-text {\n    font-size: 19px;\n    font-weight: 400;\n    line-height: 1.4;\n    color: #1A1A1A;\n    margin: 0 0 22px;\n  }\n  .eli-ing__cta-text em {\n    font-style: italic;\n    font-weight: 500;\n    color: #C9785B;\n  }\n  .eli-ing__cta-btn {\n    display: inline-block;\n    width: 100%;\n    max-width: 520px;\n    background: #C9785B;\n    color: #FFFFFF;\n    font-family: 'Poppins', sans-serif;\n    font-size: 18px;\n    font-weight: 700;\n    text-align: center;\n    text-decoration: none;\n    padding: 18px 28px;\n    border: none;\n    border-radius: 999px;\n    cursor: pointer;\n    box-shadow: 0 8px 20px rgba(201, 120, 91, 0.30);\n  }\n  .eli-ing__cta-checks {\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    gap: 22px;\n    flex-wrap: wrap;\n    margin-top: 16px;\n    font-size: 14px;\n    color: #8A8178;\n  }\n  .eli-ing__cta-checks span {\n    display: inline-flex;\n    align-items: center;\n    gap: 6px;\n  }\n  .eli-ing__cta-checks svg {\n    width: 14px;\n    height: 14px;\n    stroke: #C9785B;\n    fill: none;\n    stroke-width: 3;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n\n  /* MOBILE */\n  @media (max-width: 600px) {\n    .eli-ing { padding: 6px 2px; }\n    .eli-ing__card { border-radius: 16px; margin-bottom: 18px; }\n    .eli-ing__body { padding: 18px 18px 20px; }\n    .eli-ing__title { font-size: clamp(20px, 6.5vw, 26px); }\n    .eli-ing__subtitle { font-size: 12.5px; margin-bottom: 12px; }\n    .eli-ing__divider { margin-bottom: 14px; }\n    .eli-ing__list { gap: 11px; margin-bottom: 14px; }\n    .eli-ing__list li { font-size: 13.5px; gap: 10px; }\n    .eli-ing__badge { font-size: 12.5px; padding: 8px 14px; }\n\n    .eli-ing__cta-wrap { margin-top: 22px; }\n    .eli-ing__cta-text { font-size: 16px; margin-bottom: 16px; }\n    .eli-ing__cta-btn { font-size: 16px; padding: 16px 22px; }\n    .eli-ing__cta-checks { gap: 14px; font-size: 12.5px; margin-top: 12px; }\n  }\n</style>\n\n<div class=\"eli-ing\">\n\n  <!-- Carte 1 : Charbon Végétal Actif -->\n  <div class=\"eli-ing__card\">\n    <img class=\"eli-ing__photo\" src=\"https://cdn.shopify.com/s/files/1/0941/4010/5040/files/IMG-3391.png?width=800\" alt=\"Charbon Végétal Actif\">\n    <div class=\"eli-ing__body\">\n      <p class=\"eli-ing__eyebrow\">Ingrédient 01</p>\n      <h3 class=\"eli-ing__title\">Charbon Végétal Actif</h3>\n      <p class=\"eli-ing__subtitle\">Carbo activatus · 500mg par portion</p>\n      <div class=\"eli-ing__divider\"></div>\n\n      <ul class=\"eli-ing__list\">\n        <li>\n          <span class=\"eli-ing__dot\"></span>\n          <span><strong>Capte les gaz intestinaux</strong> — absorbe les composés responsables des ballonnements</span>\n        </li>\n        <li>\n          <span class=\"eli-ing__dot\"></span>\n          <span><strong>Réduit les flatulences</strong> — agit dès les premiers jours de cure</span>\n        </li>\n        <li>\n          <span class=\"eli-ing__dot\"></span>\n          <span><strong>D'origine végétale</strong> — sans additifs ni conservateurs</span>\n        </li>\n      </ul>\n\n      <span class=\"eli-ing__badge\">\n        <svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n        Capacité d'absorption élevée\n      </span>\n    </div>\n  </div>\n\n  <!-- Carte 2 : Fenouil & Gingembre -->\n  <div class=\"eli-ing__card\">\n    <img class=\"eli-ing__photo\" src=\"https://cdn.shopify.com/s/files/1/0941/4010/5040/files/IMG-3394.png?width=800\" alt=\"Fenouil & Gingembre\">\n    <div class=\"eli-ing__body\">\n      <p class=\"eli-ing__eyebrow\">Ingrédient 02</p>\n      <h3 class=\"eli-ing__title\">Fenouil &amp; Gingembre</h3>\n      <p class=\"eli-ing__subtitle\">Foeniculum vulgare &amp; Zingiber officinale · 200mg par portion</p>\n      <div class=\"eli-ing__divider\"></div>\n\n      <ul class=\"eli-ing__list\">\n        <li>\n          <span class=\"eli-ing__dot\"></span>\n          <span><strong>Apaise la digestion</strong> — favorise un transit plus confortable</span>\n        </li>\n        <li>\n          <span class=\"eli-ing__dot\"></span>\n          <span><strong>Réduit l'inconfort</strong> — soulage les spasmes et tensions abdominales</span>\n        </li>\n        <li>\n          <span class=\"eli-ing__dot\"></span>\n          <span><strong>Carminatif naturel</strong> — facilite l'évacuation des gaz</span>\n        </li>\n      </ul>\n\n      <span class=\"eli-ing__badge\">\n        <svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n        Utilisé en phytothérapie depuis des siècles\n      </span>\n    </div>\n  </div>\n\n  <!-- Accroche + CTA -->\n  <div class=\"eli-ing__cta-wrap\">\n    <p class=\"eli-ing__cta-text\">Deux actifs. Une formule. <em>Des résultats visibles dès les premiers jours.</em></p>\n    <a href=\"#\" class=\"eli-ing__cta-btn\" onclick=\"document.querySelector('form[action=&quot;/cart/add&quot;] button[type=submit], .product-form__submit')?.click(); return false;\">Obtenir maintenant</a>\n    <div class=\"eli-ing__cta-checks\">\n      <span>\n        <svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n        Garantie 90 jours\n      </span>\n      <span>\n        <svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n        Livraison gratuite\n      </span>\n    </div>\n  </div>\n\n</div>",
        "background": "#ffffff",
