        "remove_horizontal_spacing": true,
        "liquid": "{% comment %} ELIORA — Tableau comparatif {% endcomment %}\n\n<link href=\"https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap\" rel=\"stylesheet\">\n\n<style>\n  .eli-comp {\n    font-family: 'Poppins', sans-serif;\n    color: #1A1A1A;\n    max-width: 680px;\n    margin: 0 auto;\n    padding: 48px 20px 60px;\n  }\n\n  /* HEADER */\n  .eli-comp__head {\n    text-align: center;\n    margin-bottom: 40px;\n  }\n  .eli-comp__eyebrow {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 12px;\n    font-size: 11px;\n    font-weight: 700;\n    letter-spacing: 0.22em;\n    text-transform: uppercase;\n    color: #C9785B;\n    margin-bottom: 16px;\n  }\n  .eli-comp__eyebrow::before,\n  .eli-comp__eyebrow::after {\n    content: '';\n    height: 1px;\n    width: 40px;\n    background: #C9785B;\n    opacity: 0.5;\n  }\n  .eli-comp__title {\n    font-size: clamp(26px, 5vw, 40px);\n    font-weight: 400;\n    line-height: 1.15;\n    margin: 0 0 14px;\n    color: #1A1A1A;\n    letter-spacing: -0.02em;\n    transition: letter-spacing 0.3s ease;\n  }\n  .eli-comp__title:hover { letter-spacing: -0.01em; }\n  .eli-comp__title em {\n    font-style: italic;\n    color: #C9785B;\n  }\n  .eli-comp__subtitle {\n    font-size: 14px;\n    color: #8A8178;\n    line-height: 1.6;\n    max-width: 420px;\n    margin: 0 auto;\n  }\n\n  /* TABLE */\n  .eli-comp__table {\n    width: 100%;\n    border-collapse: separate;\n    border-spacing: 0;\n    margin-top: 32px;\n  }\n\n  /* HEADER COLONNES */\n  .eli-comp__table thead tr th {\n    padding: 0;\n    vertical-align: bottom;\n  }\n  .eli-comp__table thead tr th:first-child { width: 55%; }\n  .eli-comp__table thead tr th:not(:first-child) {\n    width: 22.5%;\n    text-align: center;\n    padding-bottom: 0;\n  }\n\n  .eli-comp__col-wrap {\n    position: relative;\n    padding: 16px 10px 14px;\n    border-radius: 16px 16px 0 0;\n  }\n  .eli-comp__col-wrap--eliora {\n    background: #FAF6F0;\n    border: 1.5px solid rgba(201,120,91,0.3);\n    border-bottom: none;\n    transition: background 0.2s ease;\n  }\n  .eli-comp__col-wrap--eliora:hover { background: rgba(201,120,91,0.08); }\n  .eli-comp__col-wrap--other { background: transparent; border: none; }\n\n  .eli-comp__badge {\n    position: absolute;\n    top: -14px;\n    left: 50%;\n    transform: translateX(-50%);\n    background: #C9785B;\n    color: #FFFFFF;\n    font-size: 9px;\n    font-weight: 700;\n    letter-spacing: 0.18em;\n    text-transform: uppercase;\n    padding: 5px 12px;\n    border-radius: 50px;\n    white-space: nowrap;\n    transition: transform 0.2s ease, box-shadow 0.2s ease;\n  }\n  .eli-comp__col-wrap--eliora:hover .eli-comp__badge {\n    transform: translateX(-50%) scale(1.06);\n    box-shadow: 0 4px 14px rgba(201,120,91,0.4);\n  }\n\n  .eli-comp__col-img {\n    width: 64px;\n    height: 64px;\n    object-fit: contain;\n    display: block;\n    margin: 8px auto 10px;\n    transition: transform 0.3s ease;\n  }\n  .eli-comp__col-wrap--eliora:hover .eli-comp__col-img {\n    transform: scale(1.1) translateY(-4px);\n  }\n\n  .eli-comp__col-img-placeholder {\n    width: 52px;\n    height: 52px;\n    margin: 8px auto 10px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 28px;\n  }\n  .eli-comp__col-name {\n    font-size: 14px;\n    font-weight: 700;\n    text-align: center;\n    margin: 0;\n  }\n  .eli-comp__col-name--eliora { color: #C9785B; }\n  .eli-comp__col-name--other { color: #8A8178; }\n\n  /* LIGNES */\n  .eli-comp__table tbody tr {\n    transition: transform 0.2s ease;\n  }\n  .eli-comp__table tbody tr:hover {\n    background: rgba(201,120,91,0.02);\n  }\n  .eli-comp__table tbody tr td {\n    padding: 15px 10px;\n    border-bottom: 1px solid rgba(26,26,26,0.07);\n    vertical-align: middle;\n    transition: background 0.2s ease;\n  }\n  .eli-comp__table tbody tr td:first-child {\n    font-size: 14px;\n    font-weight: 400;\n    color: #1A1A1A;\n    padding-left: 4px;\n    line-height: 1.45;\n  }\n  .eli-comp__table tbody tr td:not(:first-child) { text-align: center; }\n\n  /* Colonne Eliora */\n  .eli-comp__td--eliora {\n    background: #FAF6F0;\n    border-left: 1.5px solid rgba(201,120,91,0.3);\n    border-right: 1.5px solid rgba(201,120,91,0.3);\n  }\n  .eli-comp__table tbody tr:hover .eli-comp__td--eliora {\n    background: rgba(201,120,91,0.07);\n  }\n\n  /* Dernière ligne */\n  .eli-comp__table tbody tr:last-child td.eli-comp__td--eliora {\n    border-bottom: 1.5px solid rgba(201,120,91,0.3);\n    border-radius: 0 0 16px 16px;\n  }\n\n  /* ICÔNES */\n  .eli-comp__check,\n  .eli-comp__cross {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    width: 34px;\n    height: 34px;\n    border-radius: 50%;\n  }\n  .eli-comp__check {\n    background: #C9785B;\n    transition: transform 0.2s ease, box-shadow 0.2s ease;\n  }\n  .eli-comp__table tbody tr:hover .eli-comp__check {\n    transform: scale(1.18);\n    box-shadow: 0 4px 12px rgba(201,120,91,0.35);\n  }\n  .eli-comp__check svg {\n    width: 16px; height: 16px;\n    stroke: #FFFFFF; fill: none;\n    stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round;\n  }\n  .eli-comp__cross {\n    background: #EBEBEB;\n    transition: transform 0.2s ease;\n  }\n  .eli-comp__table tbody tr:hover .eli-comp__cross {\n    transform: scale(1.1);\n  }\n  .eli-comp__cross svg {\n    width: 14px; height: 14px;\n    stroke: #AAAAAA; fill: none;\n    stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round;\n  }\n\n  @media (max-width: 480px) {\n    .eli-comp__table tbody tr td:first-child { font-size: 13px; }\n    .eli-comp__col-name { font-size: 13px; }\n    .eli-comp__check, .eli-comp__cross { width: 30px; height: 30px; }\n    .eli-comp__col-img { width: 52px; height: 52px; }\n  }\n</style>\n\n<div class=\"eli-comp\">\n\n  <div class=\"eli-comp__head\">\n    <p class=\"eli-comp__eyebrow\">Tableau comparatif</p>\n    <h2 class=\"eli-comp__title\">Eliora <em>vs Autres solutions.</em></h2>\n    <p class=\"eli-comp__subtitle\">Les mêmes résultats sur le ballonnement. Sans les effets secondaires, sans la dépendance.</p>\n  </div>\n\n  <table class=\"eli-comp__table\">\n    <thead>\n      <tr>\n        <th></th>\n        <th>\n          <div class=\"eli-comp__col-wrap eli-comp__col-wrap--eliora\">\n            <span class=\"eli-comp__badge\">RECOMMANDÉ</span>\n            <img class=\"eli-comp__col-img\" src=\"https://cdn.shopify.com/s/files/1/0941/4010/5040/files/Kaching-Bundles-IMG_3421.png?v=1782225944\" alt=\"Eliora flacon\">\n            <p class=\"eli-comp__col-name eli-comp__col-name--eliora\">eliora</p>\n          </div>\n        </th>\n        <th>\n          <div class=\"eli-comp__col-wrap eli-comp__col-wrap--other\">\n            <div class=\"eli-comp__col-img-placeholder\">💊</div>\n            <p class=\"eli-comp__col-name eli-comp__col-name--other\">Autres solutions</p>\n          </div>\n        </th>\n      </tr>\n    </thead>\n    <tbody>\n      <tr>\n        <td>Agit sur les gaz à la source</td>\n        <td class=\"eli-comp__td--eliora\">\n          <span class=\"eli-comp__check\"><svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg></span>\n        </td>\n        <td>\n          <span class=\"eli-comp__cross\"><svg viewBox=\"0 0 24 24\"><line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"/><line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"/></svg></span>\n        </td>\n      </tr>\n      <tr>\n        <td>Sans effet laxatif</td>\n        <td class=\"eli-comp__td--eliora\">\n          <span class=\"eli-comp__check\"><svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg></span>\n        </td>\n        <td>\n          <span class=\"eli-comp__cross\"><svg viewBox=\"0 0 24 24\"><line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"/><line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"/></svg></span>\n        </td>\n      </tr>\n      <tr>\n        <td>Sans accoutumance</td>\n        <td class=\"eli-comp__td--eliora\">\n          <span class=\"eli-comp__check\"><svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg></span>\n        </td>\n        <td>\n          <span class=\"eli-comp__cross\"><svg viewBox=\"0 0 24 24\"><line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"/><line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"/></svg></span>\n        </td>\n      </tr>\n      <tr>\n        <td>Allégation santé autorisée UE</td>\n        <td class=\"eli-comp__td--eliora\">\n          <span class=\"eli-comp__check\"><svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg></span>\n        </td>\n        <td>\n          <span class=\"eli-comp__cross\"><svg viewBox=\"0 0 24 24\"><line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"/><line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"/></svg></span>\n        </td>\n      </tr>\n      <tr>\n        <td>100% naturel, gélule végétale</td>\n        <td class=\"eli-comp__td--eliora\">\n          <span class=\"eli-comp__check\"><svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg></span>\n        </td>\n        <td>\n          <span class=\"eli-comp__cross\"><svg viewBox=\"0 0 24 24\"><line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"/><line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"/></svg></span>\n        </td>\n      </tr>\n      <tr>\n        <td>Confort digestif durable</td>\n        <td class=\"eli-comp__td--eliora\">\n          <span class=\"eli-comp__check\"><svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg></span>\n        </td>\n        <td>\n          <span class=\"eli-comp__cross\"><svg viewBox=\"0 0 24 24\"><line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"/><line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"/></svg></span>\n        </td>\n      </tr>\n      <tr>\n        <td>Moins de 0,83€ / jour</td>\n        <td class=\"eli-comp__td--eliora\">\n          <span class=\"eli-comp__check\"><svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg></span>\n        </td>\n        <td>\n          <span class=\"eli-comp__cross\"><svg viewBox=\"0 0 24 24\"><line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"/><line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"/></svg></span>\n        </td>\n      </tr>\n    </tbody>\n  </table>\n\n</div>",
