    "custom_liquid_QCt9f8": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": false,
        "liquid": "{% comment %} ELIORA — Témoignage vidéo + Carrousel avis {% endcomment %}\n\n<link href=\"https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap\" rel=\"stylesheet\">\n\n<style>\n\n  /* ══════════════════════════════\n     SECTION VIDÉO\n  ══════════════════════════════ */\n\n  .eli-temoignage {\n    font-family: 'Poppins', sans-serif;\n    color: #1A1A1A;\n    max-width: 640px;\n    margin: 0 auto;\n    padding: 48px 20px 0;\n  }\n  .eli-temoignage__eyebrow {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 14px;\n    margin-bottom: 20px;\n  }\n  .eli-temoignage__eyebrow-line {\n    height: 1px; width: 40px;\n    background: rgba(201,120,91,0.4);\n  }\n  .eli-temoignage__eyebrow-text {\n    font-size: 11px; font-weight: 700;\n    letter-spacing: 0.22em; text-transform: uppercase;\n    color: #8A8178; white-space: nowrap;\n  }\n  .eli-temoignage__title {\n    text-align: center;\n    font-size: clamp(26px, 5.5vw, 40px);\n    font-weight: 400; line-height: 1.2;\n    letter-spacing: -0.02em;\n    margin: 0 0 32px; color: #1A1A1A;\n  }\n  .eli-temoignage__title em {\n    font-style: italic; font-weight: 400; color: #C9785B;\n  }\n\n  .eli-temoignage__video-wrap {\n    position: relative;\n    width: 100%;\n    max-width: 260px;\n    margin: 0 auto;\n    border-radius: 22px;\n    overflow: hidden;\n    background: #1A1A1A;\n    box-shadow: 0 16px 48px rgba(26,26,26,0.18);\n    aspect-ratio: 9/16;\n    cursor: pointer;\n  }\n  .eli-temoignage__video {\n    width: 100%; height: 100%;\n    object-fit: cover; display: block;\n  }\n\n  /* Indicateur pause (apparaît brièvement au clic) */\n  .eli-temoignage__pause-indicator {\n    position: absolute;\n    inset: 0;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    z-index: 2;\n    opacity: 0;\n    pointer-events: none;\n    transition: opacity 0.15s ease;\n  }\n  .eli-temoignage__pause-indicator.is-visible {\n    opacity: 1;\n  }\n  .eli-temoignage__pause-icon {\n    width: 52px; height: 52px;\n    border-radius: 50%;\n    background: rgba(255,255,255,0.85);\n    backdrop-filter: blur(6px);\n    -webkit-backdrop-filter: blur(6px);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n  .eli-temoignage__pause-icon svg {\n    width: 20px; height: 20px;\n    stroke: #1A1A1A; fill: none;\n    stroke-width: 2.5; stroke-linecap: round;\n  }\n\n  /* Badge étoiles */\n  .eli-temoignage__badge {\n    position: absolute; bottom: 14px; left: 12px;\n    display: flex; align-items: center; gap: 5px;\n    background: rgba(255,255,255,0.90);\n    backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);\n    border-radius: 50px; padding: 5px 10px; z-index: 3;\n  }\n  .eli-temoignage__badge-stars { display: inline-flex; gap: 1px; }\n  .eli-temoignage__badge-stars svg { width: 10px; height: 10px; fill: #E0A23C; }\n  .eli-temoignage__badge-text { font-size: 10px; font-weight: 600; color: #1A1A1A; white-space: nowrap; }\n\n  /* Barre de progression */\n  .eli-temoignage__progress-wrap {\n    position: absolute; bottom: 0; left: 0; right: 0;\n    height: 3px; background: rgba(255,255,255,0.20); z-index: 3;\n  }\n  .eli-temoignage__progress-bar {\n    height: 100%; width: 0%; background: #C9785B;\n    transition: width 0.1s linear;\n  }\n\n  @media (max-width: 480px) {\n    .eli-temoignage__video-wrap { max-width: 80vw; }\n    .eli-temoignage__title { font-size: clamp(22px, 6vw, 32px); }\n  }\n\n  /* ══════════════════════════════\n     SECTION CARROUSEL AVIS\n  ══════════════════════════════ */\n\n  .eli-reviews {\n    font-family: 'Poppins', sans-serif;\n    color: #1A1A1A;\n    max-width: 1100px;\n    margin: 0 auto;\n    padding: 48px 0 32px;\n  }\n  .eli-reviews__header { text-align: center; margin-bottom: 20px; padding: 0 20px; }\n  .eli-reviews__header-title {\n    font-size: clamp(20px, 4vw, 34px);\n    font-weight: 400; line-height: 1.25; margin: 0 0 4px; color: #1A1A1A;\n  }\n  .eli-reviews__header-title em { display: block; font-style: italic; font-weight: 400; color: #C9785B; }\n  .eli-reviews__badge-wrap { text-align: center; margin-bottom: 24px; }\n  .eli-reviews__badge {\n    display: inline-flex; align-items: center; gap: 8px;\n    background: #FFFFFF; border: 1px solid rgba(26,26,26,0.09);\n    border-radius: 50px; padding: 9px 18px;\n  }\n  .eli-reviews__badge-stars { display: inline-flex; gap: 2px; }\n  .eli-reviews__badge-stars svg { width: 13px; height: 13px; fill: #C9785B; }\n  .eli-reviews__badge-score { font-size: 20px; font-weight: 700; color: #1A1A1A; line-height: 1; }\n  .eli-reviews__badge-sep { width: 1px; height: 18px; background: rgba(26,26,26,0.1); }\n  .eli-reviews__badge-count { font-size: 11px; color: #8A8178; line-height: 1.35; }\n  .eli-reviews__track-wrap {\n    overflow: hidden; touch-action: pan-y;\n    -webkit-user-select: none; user-select: none; padding: 0 20px;\n  }\n  .eli-reviews__track { display: flex; gap: 12px; will-change: transform; }\n  .eli-reviews__track.is-animating { transition: transform 0.38s cubic-bezier(0.25, 1, 0.5, 1); }\n  .eli-reviews__card {\n    flex: 0 0 calc(50% - 6px); min-width: 0;\n    background: #FFFFFF; border-radius: 16px; overflow: hidden;\n    border: 1px solid rgba(26,26,26,0.07); pointer-events: none;\n  }\n  .eli-reviews__photos {\n    position: relative; height: 280px; overflow: hidden; background: #EDE6DC;\n  }\n  .eli-reviews__photo {\n    width: 100%; height: 100%; object-fit: cover; display: block; -webkit-user-drag: none;\n  }\n  .eli-reviews__photos::before {\n    content: ''; position: absolute; left: 0; right: 0; bottom: 0; height: 60px;\n    background: linear-gradient(to top, rgba(0,0,0,0.45), transparent);\n    z-index: 1; pointer-events: none;\n  }\n  .eli-reviews__photos::after {\n    content: ''; position: absolute; left: 50%; top: 0; bottom: 0; width: 1px;\n    background: rgba(255,255,255,0.45); transform: translateX(-50%);\n    pointer-events: none; z-index: 1;\n  }\n  .eli-reviews__tag {\n    position: absolute; top: 10px; left: 10px;\n    background: rgba(255,255,255,0.88);\n    backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);\n    border-radius: 50px; padding: 4px 10px;\n    font-size: 8.5px; font-weight: 700; letter-spacing: 0.13em;\n    text-transform: uppercase; color: #1A1A1A; z-index: 3;\n  }\n  .eli-reviews__label--avant {\n    position: absolute; bottom: 10px; left: 0; width: 50%;\n    text-align: center; font-size: 9.5px; font-weight: 700;\n    letter-spacing: 0.14em; text-transform: uppercase;\n    color: rgba(255,255,255,0.95); z-index: 3;\n  }\n  .eli-reviews__label--apres {\n    position: absolute; bottom: 8px; right: 0; width: 50%;\n    display: flex; flex-direction: column; align-items: center; gap: 0; z-index: 3;\n  }\n  .eli-reviews__label--apres span {\n    font-size: 9.5px; font-weight: 700; letter-spacing: 0.14em;\n    text-transform: uppercase; color: rgba(255,255,255,0.95);\n  }\n  .eli-reviews__label--apres small {\n    font-size: 9px; font-style: italic; font-weight: 500; color: #F0C9A8;\n  }\n  .eli-reviews__body { padding: 14px 14px 16px; }\n  .eli-reviews__name {\n    font-size: 15px; font-weight: 700; margin: 0 0 5px; color: #1A1A1A;\n    display: flex; align-items: center; gap: 6px;\n  }\n  .eli-reviews__name-stars { display: inline-flex; gap: 1px; }\n  .eli-reviews__name-stars svg { width: 11px; height: 11px; fill: #C9785B; }\n  .eli-reviews__text {\n    font-size: 12px; line-height: 1.6; color: #4A4640; margin: 0; font-style: italic;\n  }\n  .eli-reviews__text strong { font-style: normal; font-weight: 600; color: #1A1A1A; }\n  .eli-reviews__nav {\n    display: flex; align-items: center; justify-content: center;\n    gap: 10px; margin-top: 18px; padding: 0 20px;\n  }\n  .eli-reviews__nav-label { font-size: 12px; color: #8A8178; font-weight: 400; }\n  .eli-reviews__dots { display: flex; gap: 6px; align-items: center; }\n  .eli-reviews__dot {\n    width: 8px; height: 8px; border-radius: 50%; background: #D9CDBE;\n    transition: background 0.25s, width 0.25s, border-radius 0.25s;\n    cursor: pointer; border: none; padding: 0; flex-shrink: 0;\n  }\n  .eli-reviews__dot.is-active { width: 24px; border-radius: 4px; background: #C9785B; }\n\n  @media (min-width: 768px) {\n    .eli-reviews__photos { height: 340px; }\n    .eli-reviews__track-wrap { padding: 0 40px; }\n  }\n  @media (max-width: 600px) {\n    .eli-reviews { padding: 28px 0 24px; }\n    .eli-reviews__track-wrap { padding: 0; }\n    .eli-reviews__card { flex: 0 0 calc(100vw - 52px); border-radius: 14px; }\n    .eli-reviews__card:first-child { margin-left: 16px; }\n    .eli-reviews__photos { height: 230px; }\n    .eli-reviews__body { padding: 12px 12px 14px; }\n    .eli-reviews__name { font-size: 14px; }\n    .eli-reviews__text { font-size: 11.5px; }\n  }\n</style>\n\n<!-- ══════ VIDÉO ══════ -->\n<div class=\"eli-temoignage\">\n\n  <div class=\"eli-temoignage__eyebrow\">\n    <span class=\"eli-temoignage__eyebrow-line\"></span>\n    <span class=\"eli-temoignage__eyebrow-text\">Témoignages vérifiés</span>\n    <span class=\"eli-temoignage__eyebrow-line\"></span>\n  </div>\n\n  <h2 class=\"eli-temoignage__title\">\n    Vous ballonnez depuis des mois —\n    <em>et vous n'en pouvez plus.</em>\n  </h2>\n\n  <div class=\"eli-temoignage__video-wrap\" id=\"eliVideoWrap\">\n\n    <video\n      class=\"eli-temoignage__video\"\n      id=\"eliVideo\"\n      src=\"https://cdn.shopify.com/videos/c/o/v/92467c798fc44dd796f0532a2f6f6537.mp4\"\n      autoplay\n      muted\n      loop\n      playsinline\n      preload=\"auto\"\n    ></video>\n\n    <!-- Indicateur pause/play au clic -->\n    <div class=\"eli-temoignage__pause-indicator\" id=\"eliPauseIndicator\">\n      <div class=\"eli-temoignage__pause-icon\" id=\"eliPauseIcon\">\n        <svg id=\"eliIconPause\" viewBox=\"0 0 24 24\"><line x1=\"6\" y1=\"4\" x2=\"6\" y2=\"20\"/><line x1=\"18\" y1=\"4\" x2=\"18\" y2=\"20\"/></svg>\n        <svg id=\"eliIconPlay\" viewBox=\"0 0 24 24\" style=\"display:none\"><polygon points=\"5 3 19 12 5 21 5 3\" fill=\"#1A1A1A\" stroke=\"none\"/></svg>\n      </div>\n    </div>\n\n    <!-- Badge étoiles -->\n    <div class=\"eli-temoignage__badge\">\n      <span class=\"eli-temoignage__badge-stars\">\n        <svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg>\n        <svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg>\n        <svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg>\n        <svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg>\n        <svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg>\n      </span>\n      <span class=\"eli-temoignage__badge-text\">Achat vérifié</span>\n    </div>\n\n    <!-- Barre de progression -->\n    <div class=\"eli-temoignage__progress-wrap\">\n      <div class=\"eli-temoignage__progress-bar\" id=\"eliProgressBar\"></div>\n    </div>\n\n  </div>\n</div>\n\n<!-- ══════ CARROUSEL AVIS ══════ -->\n<section class=\"eli-reviews\">\n\n  <div class=\"eli-reviews__header\">\n    <h2 class=\"eli-reviews__header-title\">\n      Elles aussi. Voici ce\n      <em>qui a enfin marché pour elles.</em>\n    </h2>\n  </div>\n\n  <div class=\"eli-reviews__badge-wrap\">\n    <div class=\"eli-reviews__badge\">\n      <span class=\"eli-reviews__badge-stars\">\n        <svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg>\n        <svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg>\n        <svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg>\n        <svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg>\n        <svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg>\n      </span>\n      <span class=\"eli-reviews__badge-score\">4.8</span>\n      <span class=\"eli-reviews__badge-sep\"></span>\n      <span class=\"eli-reviews__badge-count\">basé sur +10 000 avis</span>\n    </div>\n  </div>\n\n  <div class=\"eli-reviews__track-wrap\" id=\"eliTrackWrap\">\n    <div class=\"eli-reviews__track\" id=\"eliTrack\">\n\n      <div class=\"eli-reviews__card\">\n        <div class=\"eli-reviews__photos\">\n          <span class=\"eli-reviews__tag\">Ventre gonflé</span>\n          <img class=\"eli-reviews__photo\" src=\"https://cdn.shopify.com/s/files/1/0941/4010/5040/files/IMG-3408.jpg?v=1782223436\" alt=\"Avant après Camille\" loading=\"lazy\">\n          <span class=\"eli-reviews__label--avant\">Avant</span>\n          <div class=\"eli-reviews__label--apres\"><span>Après</span><small>eliora</small></div>\n        </div>\n        <div class=\"eli-reviews__body\">\n          <p class=\"eli-reviews__name\">Camille <span class=\"eli-reviews__name-stars\"><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg></span></p>\n          <p class=\"eli-reviews__text\">« Mon ventre gonflait après chaque repas, même les plus légers. <strong>Dès la première semaine, les ballonnements ont vraiment diminué. Après 3 semaines, je me sens légère toute la journée.</strong> »</p>\n        </div>\n      </div>\n\n      <div class=\"eli-reviews__card\">\n        <div class=\"eli-reviews__photos\">\n          <span class=\"eli-reviews__tag\">Gaz & inconforts</span>\n          <img class=\"eli-reviews__photo\" src=\"https://cdn.shopify.com/s/files/1/0941/4010/5040/files/IMG-3411.jpg?v=1782223435\" alt=\"Avant après Sofia\" loading=\"lazy\">\n          <span class=\"eli-reviews__label--avant\">Avant</span>\n          <div class=\"eli-reviews__label--apres\"><span>Après</span><small>eliora</small></div>\n        </div>\n        <div class=\"eli-reviews__body\">\n          <p class=\"eli-reviews__name\">Sofia <span class=\"eli-reviews__name-stars\"><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg></span></p>\n          <p class=\"eli-reviews__text\">« J'avais des gaz et des crampes après chaque repas depuis des années. <strong>Avec Eliora, l'inconfort a disparu en 2 semaines.</strong> J'ai enfin arrêté d'éviter les repas en société. »</p>\n        </div>\n      </div>\n\n      <div class=\"eli-reviews__card\">\n        <div class=\"eli-reviews__photos\">\n          <span class=\"eli-reviews__tag\">Digestion lente</span>\n          <img class=\"eli-reviews__photo\" src=\"https://cdn.shopify.com/s/files/1/0941/4010/5040/files/IMG-3412.jpg?v=1782223436\" alt=\"Avant après Léa\" loading=\"lazy\">\n          <span class=\"eli-reviews__label--avant\">Avant</span>\n          <div class=\"eli-reviews__label--apres\"><span>Après</span><small>eliora</small></div>\n        </div>\n        <div class=\"eli-reviews__body\">\n          <p class=\"eli-reviews__name\">Léa <span class=\"eli-reviews__name-stars\"><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg></span></p>\n          <p class=\"eli-reviews__text\">« Ma digestion était très lente, je me sentais lourde des heures après manger. <strong>Eliora a vraiment accéléré ma digestion et réduit les lourdeurs.</strong> Je le recommande à toutes mes amies. »</p>\n        </div>\n      </div>\n\n      <div class=\"eli-reviews__card\">\n        <div class=\"eli-reviews__photos\">\n          <span class=\"eli-reviews__tag\">Ventre plat</span>\n          <img class=\"eli-reviews__photo\" src=\"https://cdn.shopify.com/s/files/1/0941/4010/5040/files/IMG-3413.jpg?v=1782223435\" alt=\"Avant après Marine\" loading=\"lazy\">\n          <span class=\"eli-reviews__label--avant\">Avant</span>\n          <div class=\"eli-reviews__label--apres\"><span>Après</span><small>eliora</small></div>\n        </div>\n        <div class=\"eli-reviews__body\">\n          <p class=\"eli-reviews__name\">Marine <span class=\"eli-reviews__name-stars\"><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg></span></p>\n          <p class=\"eli-reviews__text\">« Je me réveillais avec un ventre plat et le soir il était gonflé. <strong>Depuis Eliora, ce gonflement du soir a presque disparu. 4 semaines et je remets mes jeans slim.</strong> »</p>\n        </div>\n      </div>\n\n      <div class=\"eli-reviews__card\">\n        <div class=\"eli-reviews__photos\">\n          <span class=\"eli-reviews__tag\">Confort digestif</span>\n          <img class=\"eli-reviews__photo\" src=\"https://cdn.shopify.com/s/files/1/0941/4010/5040/files/FullSizeRender.jpg?v=1782223435\" alt=\"Avant après Inès\" loading=\"lazy\">\n          <span class=\"eli-reviews__label--avant\">Avant</span>\n          <div class=\"eli-reviews__label--apres\"><span>Après</span><small>eliora</small></div>\n        </div>\n        <div class=\"eli-reviews__body\">\n          <p class=\"eli-reviews__name\">Inès <span class=\"eli-reviews__name-stars\"><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg></span></p>\n          <p class=\"eli-reviews__text\">« J'avais des digestions difficiles depuis des années, j'avais perdu espoir. <strong>Eliora est la première chose qui m'a vraiment soulagée, en douceur et sans effets secondaires.</strong> »</p>\n        </div>\n      </div>\n\n      <div class=\"eli-reviews__card\">\n        <div class=\"eli-reviews__photos\">\n          <span class=\"eli-reviews__tag\">Après les repas</span>\n          <img class=\"eli-reviews__photo\" src=\"https://cdn.shopify.com/s/files/1/0941/4010/5040/files/IMG-3418.png?v=1782223436\" alt=\"Avant après Julie\" loading=\"lazy\">\n          <span class=\"eli-reviews__label--avant\">Avant</span>\n          <div class=\"eli-reviews__label--apres\"><span>Après</span><small>eliora</small></div>\n        </div>\n        <div class=\"eli-reviews__body\">\n          <p class=\"eli-reviews__name\">Julie <span class=\"eli-reviews__name-stars\"><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg></span></p>\n          <p class=\"eli-reviews__text\">« Après chaque déjeuner je devais déboutonner mon pantalon tellement je gonflais. <strong>Maintenant je mange normalement, aucun gonflement. Eliora a changé mon quotidien.</strong> »</p>\n        </div>\n      </div>\n\n      <div class=\"eli-reviews__card\">\n        <div class=\"eli-reviews__photos\">\n          <span class=\"eli-reviews__tag\">Ventre léger</span>\n          <img class=\"eli-reviews__photo\" src=\"https://cdn.shopify.com/s/files/1/0941/4010/5040/files/IMG-3419.png?v=1782223437\" alt=\"Avant après Émilie\" loading=\"lazy\">\n          <span class=\"eli-reviews__label--avant\">Avant</span>\n          <div class=\"eli-reviews__label--apres\"><span>Après</span><small>eliora</small></div>\n        </div>\n        <div class=\"eli-reviews__body\">\n          <p class=\"eli-reviews__name\">Émilie <span class=\"eli-reviews__name-stars\"><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg></span></p>\n          <p class=\"eli-reviews__text\">« En fin de journée j'étais tellement ballonnée que c'en était inconfortable. <strong>Avec Eliora je me sens légère du matin au soir, c'est un vrai soulagement au quotidien.</strong> »</p>\n        </div>\n      </div>\n\n    </div>\n  </div>\n\n  <div class=\"eli-reviews__nav\">\n    <span class=\"eli-reviews__nav-label\">Glisser →</span>\n    <div class=\"eli-reviews__dots\" id=\"eliDots\"></div>\n  </div>\n\n</section>\n\n<script>\n(function() {\n  /* ── VIDÉO autoplay muted, pause/play au clic ── */\n  var video = document.getElementById('eliVideo');\n  var indicator = document.getElementById('eliPauseIndicator');\n  var iconPause = document.getElementById('eliIconPause');\n  var iconPlay = document.getElementById('eliIconPlay');\n  var progress = document.getElementById('eliProgressBar');\n  var hideTimer;\n\n  if (video) {\n    /* Clic = toggle pause/play avec indicateur bref */\n    video.addEventListener('click', function() {\n      if (video.paused) {\n        video.play();\n        iconPause.style.display = 'block';\n        iconPlay.style.display = 'none';\n      } else {\n        video.pause();\n        iconPause.style.display = 'none';\n        iconPlay.style.display = 'block';\n      }\n      indicator.classList.add('is-visible');\n      clearTimeout(hideTimer);\n      hideTimer = setTimeout(function() {\n        indicator.classList.remove('is-visible');\n      }, 800);\n    });\n\n    /* Barre de progression */\n    video.addEventListener('timeupdate', function() {\n      if (video.duration) {\n        progress.style.width = ((video.currentTime / video.duration) * 100) + '%';\n      }\n    });\n  }\n\n  /* ── CARROUSEL ── */\n  var wrap = document.getElementById('eliTrackWrap');\n  var track = document.getElementById('eliTrack');\n  var dotsWrap = document.getElementById('eliDots');\n  if (!wrap || !track) return;\n  var cards = track.querySelectorAll('.eli-reviews__card');\n  var total = cards.length;\n  var current = 0, startX = 0, startY = 0, currentX = 0;\n  var isDragging = false, isHorizontal = null, baseOffset = 0;\n\n  function getVisible() { return window.innerWidth >= 600 ? 2 : 1; }\n  function getCardW() { return cards[0] ? cards[0].offsetWidth + 12 : 0; }\n  function maxIndex() { return Math.max(0, total - getVisible()); }\n  function setTranslate(x, animate) {\n    if (animate) track.classList.add('is-animating'); else track.classList.remove('is-animating');\n    track.style.transform = 'translateX(' + x + 'px)';\n  }\n  function goTo(idx) {\n    current = Math.max(0, Math.min(idx, maxIndex()));\n    baseOffset = -(current * getCardW());\n    setTranslate(baseOffset, true); updateDots();\n  }\n  function updateDots() {\n    dotsWrap.querySelectorAll('.eli-reviews__dot').forEach(function(d, i) { d.classList.toggle('is-active', i === current); });\n  }\n  function buildDots() {\n    dotsWrap.innerHTML = '';\n    for (var i = 0; i <= maxIndex(); i++) {\n      var btn = document.createElement('button');\n      btn.className = 'eli-reviews__dot' + (i === 0 ? ' is-active' : '');\n      btn.setAttribute('aria-label', 'Slide ' + (i + 1));\n      (function(idx) { btn.addEventListener('click', function() { goTo(idx); }); })(i);\n      dotsWrap.appendChild(btn);\n    }\n  }\n  buildDots();\n\n  wrap.addEventListener('touchstart', function(e) { startX = e.touches[0].clientX; startY = e.touches[0].clientY; currentX = startX; isDragging = true; isHorizontal = null; track.classList.remove('is-animating'); }, { passive: true });\n  wrap.addEventListener('touchmove', function(e) {\n    if (!isDragging) return;\n    var dx = e.touches[0].clientX - startX, dy = e.touches[0].clientY - startY;\n    if (isHorizontal === null) isHorizontal = Math.abs(dx) > Math.abs(dy);\n    if (!isHorizontal) return;\n    e.preventDefault(); currentX = e.touches[0].clientX;\n    setTranslate(baseOffset + (currentX - startX), false);\n  }, { passive: false });\n  wrap.addEventListener('touchend', function() {\n    if (!isDragging) return; isDragging = false;\n    var delta = currentX - startX;\n    if (isHorizontal) { if (delta < -40) goTo(current + 1); else if (delta > 40) goTo(current - 1); else goTo(current); }\n    isHorizontal = null;\n  });\n  wrap.addEventListener('mousedown', function(e) { if (e.button !== 0) return; startX = e.clientX; currentX = e.clientX; isDragging = true; track.classList.remove('is-animating'); wrap.style.cursor = 'grabbing'; });\n  window.addEventListener('mousemove', function(e) { if (!isDragging) return; currentX = e.clientX; setTranslate(baseOffset + (currentX - startX), false); });\n  window.addEventListener('mouseup', function() { if (!isDragging) return; isDragging = false; wrap.style.cursor = ''; var delta = currentX - startX; if (delta < -40) goTo(current + 1); else if (delta > 40) goTo(current - 1); else goTo(current); });\n  window.addEventListener('resize', function() { buildDots(); baseOffset = -(current * getCardW()); setTranslate(baseOffset, false); });\n})();\n</script>",
        "background": "",
        "background_gradient": "",
        "text_color": ""
      }
    },
    "custom_liquid_PXbETE": {
      "type": "custom-liquid",
      "disabled": true,
      "name": "Custom Liquid",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": true,
        "liquid": "{% comment %} ELIORA — Témoignages Avant/Après carousel {% endcomment %}\n\n<link href=\"https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap\" rel=\"stylesheet\">\n\n<style>\n  .eli-reviews {\n    font-family: 'Poppins', -apple-system, BlinkMacSystemFont, sans-serif;\n    color: #1A1A1A;\n    max-width: 1100px;\n    margin: 0 auto;\n    padding: 40px 0 32px;\n  }\n  .eli-reviews__header { text-align: center; margin-bottom: 20px; padding: 0 20px; }\n  .eli-reviews__header-title {\n    font-size: clamp(20px, 4vw, 34px);\n    font-weight: 400; line-height: 1.25; margin: 0 0 4px; color: #1A1A1A;\n  }\n  .eli-reviews__header-title em { display: block; font-style: italic; font-weight: 400; color: #C9785B; }\n  .eli-reviews__badge-wrap { text-align: center; margin-bottom: 24px; }\n  .eli-reviews__badge {\n    display: inline-flex; align-items: center; gap: 8px;\n    background: #FFFFFF; border: 1px solid rgba(26,26,26,0.09);\n    border-radius: 50px; padding: 9px 18px;\n  }\n  .eli-reviews__badge-stars { display: inline-flex; gap: 2px; }\n  .eli-reviews__badge-stars svg { width: 13px; height: 13px; fill: #C9785B; }\n  .eli-reviews__badge-score { font-size: 20px; font-weight: 700; color: #1A1A1A; line-height: 1; }\n  .eli-reviews__badge-sep { width: 1px; height: 18px; background: rgba(26,26,26,0.1); }\n  .eli-reviews__badge-count { font-size: 11px; color: #8A8178; line-height: 1.35; }\n\n  .eli-reviews__track-wrap {\n    overflow: hidden; touch-action: pan-y;\n    -webkit-user-select: none; user-select: none; padding: 0 20px;\n  }\n  .eli-reviews__track { display: flex; gap: 12px; will-change: transform; }\n  .eli-reviews__track.is-animating { transition: transform 0.38s cubic-bezier(0.25, 1, 0.5, 1); }\n\n  .eli-reviews__card {\n    flex: 0 0 calc(50% - 6px); min-width: 0;\n    background: #FFFFFF; border-radius: 16px; overflow: hidden;\n    border: 1px solid rgba(26,26,26,0.07); pointer-events: none;\n  }\n\n  .eli-reviews__photos {\n    position: relative; height: 280px; overflow: hidden; background: #EDE6DC;\n  }\n  .eli-reviews__photo {\n    width: 100%; height: 100%; object-fit: cover; display: block; -webkit-user-drag: none;\n  }\n  /* dégradé bas pour lisibilité des labels */\n  .eli-reviews__photos::before {\n    content: ''; position: absolute; left: 0; right: 0; bottom: 0; height: 60px;\n    background: linear-gradient(to top, rgba(0,0,0,0.45), transparent);\n    z-index: 1; pointer-events: none;\n  }\n  /* trait vertical au milieu */\n  .eli-reviews__photos::after {\n    content: ''; position: absolute; left: 50%; top: 0; bottom: 0; width: 1px;\n    background: rgba(255,255,255,0.45); transform: translateX(-50%);\n    pointer-events: none; z-index: 1;\n  }\n  .eli-reviews__tag {\n    position: absolute; top: 10px; left: 10px;\n    background: rgba(255,255,255,0.88);\n    backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);\n    border-radius: 50px; padding: 4px 10px;\n    font-size: 8.5px; font-weight: 700; letter-spacing: 0.13em;\n    text-transform: uppercase; color: #1A1A1A; z-index: 3;\n  }\n  .eli-reviews__label--avant {\n    position: absolute; bottom: 10px; left: 0; width: 50%;\n    text-align: center;\n    font-size: 9.5px; font-weight: 700; letter-spacing: 0.14em;\n    text-transform: uppercase; color: rgba(255,255,255,0.95); z-index: 3;\n  }\n  .eli-reviews__label--apres {\n    position: absolute; bottom: 8px; right: 0; width: 50%;\n    display: flex; flex-direction: column; align-items: center; gap: 0; z-index: 3;\n  }\n  .eli-reviews__label--apres span {\n    font-size: 9.5px; font-weight: 700; letter-spacing: 0.14em;\n    text-transform: uppercase; color: rgba(255,255,255,0.95);\n  }\n  .eli-reviews__label--apres small {\n    font-size: 9px; font-style: italic; font-weight: 500;\n    color: #F0C9A8;\n  }\n\n  .eli-reviews__body { padding: 14px 14px 16px; }\n  .eli-reviews__name {\n    font-size: 15px; font-weight: 700; margin: 0 0 5px; color: #1A1A1A;\n    display: flex; align-items: center; gap: 6px;\n  }\n  .eli-reviews__name-stars { display: inline-flex; gap: 1px; }\n  .eli-reviews__name-stars svg { width: 11px; height: 11px; fill: #C9785B; }\n  .eli-reviews__text {\n    font-size: 12px; line-height: 1.6; color: #4A4640; margin: 0; font-style: italic;\n  }\n  .eli-reviews__text strong { font-style: normal; font-weight: 600; color: #1A1A1A; }\n\n  .eli-reviews__nav {\n    display: flex; align-items: center; justify-content: center;\n    gap: 10px; margin-top: 18px; padding: 0 20px;\n  }\n  .eli-reviews__nav-label { font-size: 12px; color: #8A8178; font-weight: 400; }\n  .eli-reviews__dots { display: flex; gap: 6px; align-items: center; }\n  .eli-reviews__dot {\n    width: 8px; height: 8px; border-radius: 50%; background: #D9CDBE;\n    transition: background 0.25s, width 0.25s, border-radius 0.25s;\n    cursor: pointer; border: none; padding: 0; flex-shrink: 0;\n  }\n  .eli-reviews__dot.is-active { width: 24px; border-radius: 4px; background: #C9785B; }\n\n  @media (min-width: 768px) {\n    .eli-reviews__photos { height: 340px; }\n    .eli-reviews__track-wrap { padding: 0 40px; }\n  }\n  @media (max-width: 600px) {\n    .eli-reviews { padding: 28px 0 24px; }\n    .eli-reviews__track-wrap { padding: 0; }\n    .eli-reviews__card { flex: 0 0 calc(100vw - 52px); border-radius: 14px; }\n    .eli-reviews__card:first-child { margin-left: 16px; }\n    .eli-reviews__photos { height: 230px; }\n    .eli-reviews__body { padding: 12px 12px 14px; }\n    .eli-reviews__name { font-size: 14px; }\n    .eli-reviews__text { font-size: 11.5px; }\n  }\n</style>\n\n<section class=\"eli-reviews\">\n\n  <div class=\"eli-reviews__header\">\n    <h2 class=\"eli-reviews__header-title\">\n      Elles aussi. Voici ce\n      <em>qui a enfin marché pour elles.</em>\n    </h2>\n  </div>\n\n  <div class=\"eli-reviews__badge-wrap\">\n    <div class=\"eli-reviews__badge\">\n      <span class=\"eli-reviews__badge-stars\">\n        <svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg>\n        <svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg>\n        <svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg>\n        <svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg>\n        <svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg>\n      </span>\n      <span class=\"eli-reviews__badge-score\">4.8</span>\n      <span class=\"eli-reviews__badge-sep\"></span>\n      <span class=\"eli-reviews__badge-count\">basé sur +10 000 avis</span>\n    </div>\n  </div>\n\n  <div class=\"eli-reviews__track-wrap\" id=\"eliTrackWrap\">\n    <div class=\"eli-reviews__track\" id=\"eliTrack\">\n\n      <div class=\"eli-reviews__card\">\n        <div class=\"eli-reviews__photos\">\n          <span class=\"eli-reviews__tag\">Ventre gonflé</span>\n          <img class=\"eli-reviews__photo\" src=\"https://cdn.shopify.com/s/files/1/0941/4010/5040/files/IMG-3408.jpg?v=1782223436\" alt=\"Avant après Camille\" loading=\"lazy\">\n          <span class=\"eli-reviews__label--avant\">Avant</span>\n          <div class=\"eli-reviews__label--apres\"><span>Après</span><small>eliora</small></div>\n        </div>\n        <div class=\"eli-reviews__body\">\n          <p class=\"eli-reviews__name\">Camille <span class=\"eli-reviews__name-stars\"><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg></span></p>\n          <p class=\"eli-reviews__text\">« Mon ventre gonflait après chaque repas, même les plus légers. <strong>Dès la première semaine, les ballonnements ont vraiment diminué. Après 3 semaines, je me sens légère toute la journée.</strong> »</p>\n        </div>\n      </div>\n\n      <div class=\"eli-reviews__card\">\n        <div class=\"eli-reviews__photos\">\n          <span class=\"eli-reviews__tag\">Gaz & inconforts</span>\n          <img class=\"eli-reviews__photo\" src=\"https://cdn.shopify.com/s/files/1/0941/4010/5040/files/IMG-3411.jpg?v=1782223435\" alt=\"Avant après Sofia\" loading=\"lazy\">\n          <span class=\"eli-reviews__label--avant\">Avant</span>\n          <div class=\"eli-reviews__label--apres\"><span>Après</span><small>eliora</small></div>\n        </div>\n        <div class=\"eli-reviews__body\">\n          <p class=\"eli-reviews__name\">Sofia <span class=\"eli-reviews__name-stars\"><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg></span></p>\n          <p class=\"eli-reviews__text\">« J'avais des gaz et des crampes après chaque repas depuis des années. <strong>Avec Eliora, l'inconfort a disparu en 2 semaines.</strong> J'ai enfin arrêté d'éviter les repas en société. »</p>\n        </div>\n      </div>\n\n      <div class=\"eli-reviews__card\">\n        <div class=\"eli-reviews__photos\">\n          <span class=\"eli-reviews__tag\">Digestion lente</span>\n          <img class=\"eli-reviews__photo\" src=\"https://cdn.shopify.com/s/files/1/0941/4010/5040/files/IMG-3412.jpg?v=1782223436\" alt=\"Avant après Léa\" loading=\"lazy\">\n          <span class=\"eli-reviews__label--avant\">Avant</span>\n          <div class=\"eli-reviews__label--apres\"><span>Après</span><small>eliora</small></div>\n        </div>\n        <div class=\"eli-reviews__body\">\n          <p class=\"eli-reviews__name\">Léa <span class=\"eli-reviews__name-stars\"><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg></span></p>\n          <p class=\"eli-reviews__text\">« Ma digestion était très lente, je me sentais lourde des heures après manger. <strong>Eliora a vraiment accéléré ma digestion et réduit les lourdeurs.</strong> Je le recommande à toutes mes amies. »</p>\n        </div>\n      </div>\n\n      <div class=\"eli-reviews__card\">\n        <div class=\"eli-reviews__photos\">\n          <span class=\"eli-reviews__tag\">Ventre plat</span>\n          <img class=\"eli-reviews__photo\" src=\"https://cdn.shopify.com/s/files/1/0941/4010/5040/files/IMG-3413.jpg?v=1782223435\" alt=\"Avant après Marine\" loading=\"lazy\">\n          <span class=\"eli-reviews__label--avant\">Avant</span>\n          <div class=\"eli-reviews__label--apres\"><span>Après</span><small>eliora</small></div>\n        </div>\n        <div class=\"eli-reviews__body\">\n          <p class=\"eli-reviews__name\">Marine <span class=\"eli-reviews__name-stars\"><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg></span></p>\n          <p class=\"eli-reviews__text\">« Je me réveillais avec un ventre plat et le soir il était gonflé. <strong>Depuis Eliora, ce gonflement du soir a presque disparu. 4 semaines et je remets mes jeans slim.</strong> »</p>\n        </div>\n      </div>\n\n      <div class=\"eli-reviews__card\">\n        <div class=\"eli-reviews__photos\">\n          <span class=\"eli-reviews__tag\">Confort digestif</span>\n          <img class=\"eli-reviews__photo\" src=\"https://cdn.shopify.com/s/files/1/0941/4010/5040/files/FullSizeRender.jpg?v=1782223435\" alt=\"Avant après Inès\" loading=\"lazy\">\n          <span class=\"eli-reviews__label--avant\">Avant</span>\n          <div class=\"eli-reviews__label--apres\"><span>Après</span><small>eliora</small></div>\n        </div>\n        <div class=\"eli-reviews__body\">\n          <p class=\"eli-reviews__name\">Inès <span class=\"eli-reviews__name-stars\"><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg></span></p>\n          <p class=\"eli-reviews__text\">« J'avais des digestions difficiles depuis des années, j'avais perdu espoir. <strong>Eliora est la première chose qui m'a vraiment soulagée, en douceur et sans effets secondaires.</strong> »</p>\n        </div>\n      </div>\n\n      <div class=\"eli-reviews__card\">\n        <div class=\"eli-reviews__photos\">\n          <span class=\"eli-reviews__tag\">Après les repas</span>\n          <img class=\"eli-reviews__photo\" src=\"https://cdn.shopify.com/s/files/1/0941/4010/5040/files/IMG-3418.png?v=1782223436\" alt=\"Avant après Julie\" loading=\"lazy\">\n          <span class=\"eli-reviews__label--avant\">Avant</span>\n          <div class=\"eli-reviews__label--apres\"><span>Après</span><small>eliora</small></div>\n        </div>\n        <div class=\"eli-reviews__body\">\n          <p class=\"eli-reviews__name\">Julie <span class=\"eli-reviews__name-stars\"><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg></span></p>\n          <p class=\"eli-reviews__text\">« Après chaque déjeuner je devais déboutonner mon pantalon tellement je gonflais. <strong>Maintenant je mange normalement, aucun gonflement. Eliora a changé mon quotidien.</strong> »</p>\n        </div>\n      </div>\n\n      <div class=\"eli-reviews__card\">\n        <div class=\"eli-reviews__photos\">\n          <span class=\"eli-reviews__tag\">Ventre léger</span>\n          <img class=\"eli-reviews__photo\" src=\"https://cdn.shopify.com/s/files/1/0941/4010/5040/files/IMG-3419.png?v=1782223437\" alt=\"Avant après Émilie\" loading=\"lazy\">\n          <span class=\"eli-reviews__label--avant\">Avant</span>\n          <div class=\"eli-reviews__label--apres\"><span>Après</span><small>eliora</small></div>\n        </div>\n        <div class=\"eli-reviews__body\">\n          <p class=\"eli-reviews__name\">Émilie <span class=\"eli-reviews__name-stars\"><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg><svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg></span></p>\n          <p class=\"eli-reviews__text\">« En fin de journée j'étais tellement ballonnée que c'en était inconfortable. <strong>Avec Eliora je me sens légère du matin au soir, c'est un vrai soulagement au quotidien.</strong> »</p>\n        </div>\n      </div>\n\n    </div>\n  </div>\n\n  <div class=\"eli-reviews__nav\">\n    <span class=\"eli-reviews__nav-label\">Glisser →</span>\n    <div class=\"eli-reviews__dots\" id=\"eliDots\"></div>\n  </div>\n\n</section>\n\n<script>\n(function() {\n  var wrap = document.getElementById('eliTrackWrap');\n  var track = document.getElementById('eliTrack');\n  var dotsWrap = document.getElementById('eliDots');\n  if (!wrap || !track) return;\n  var cards = track.querySelectorAll('.eli-reviews__card');\n  var total = cards.length;\n  var current = 0, startX = 0, startY = 0, currentX = 0;\n  var isDragging = false, isHorizontal = null, baseOffset = 0;\n\n  function getVisible() { return window.innerWidth >= 600 ? 2 : 1; }\n  function getCardW() { return cards[0] ? cards[0].offsetWidth + 12 : 0; }\n  function maxIndex() { return Math.max(0, total - getVisible()); }\n  function setTranslate(x, animate) {\n    if (animate) track.classList.add('is-animating'); else track.classList.remove('is-animating');\n    track.style.transform = 'translateX(' + x + 'px)';\n  }\n  function goTo(idx) {\n    current = Math.max(0, Math.min(idx, maxIndex()));\n    baseOffset = -(current * getCardW());\n    setTranslate(baseOffset, true); updateDots();\n  }\n  function updateDots() {\n    dotsWrap.querySelectorAll('.eli-reviews__dot').forEach(function(d, i) { d.classList.toggle('is-active', i === current); });\n  }\n  function buildDots() {\n    dotsWrap.innerHTML = '';\n    var count = maxIndex() + 1;\n    for (var i = 0; i < count; i++) {\n      var btn = document.createElement('button');\n      btn.className = 'eli-reviews__dot' + (i === 0 ? ' is-active' : '');\n      btn.setAttribute('aria-label', 'Slide ' + (i + 1));\n      (function(idx) { btn.addEventListener('click', function() { goTo(idx); }); })(i);\n      dotsWrap.appendChild(btn);\n    }\n  }\n  buildDots(); baseOffset = 0;\n\n  wrap.addEventListener('touchstart', function(e) {\n    startX = e.touches[0].clientX; startY = e.touches[0].clientY; currentX = startX;\n    isDragging = true; isHorizontal = null; track.classList.remove('is-animating');\n  }, { passive: true });\n  wrap.addEventListener('touchmove', function(e) {\n    if (!isDragging) return;\n    var dx = e.touches[0].clientX - startX, dy = e.touches[0].clientY - startY;\n    if (isHorizontal === null) isHorizontal = Math.abs(dx) > Math.abs(dy);\n    if (!isHorizontal) return;\n    e.preventDefault(); currentX = e.touches[0].clientX;\n    setTranslate(baseOffset + (currentX - startX), false);\n  }, { passive: false });\n  wrap.addEventListener('touchend', function() {\n    if (!isDragging) return; isDragging = false;\n    var delta = currentX - startX;\n    if (isHorizontal) {\n      if (delta < -40) goTo(current + 1);\n      else if (delta > 40) goTo(current - 1);\n      else goTo(current);\n    }\n    isHorizontal = null;\n  });\n  wrap.addEventListener('mousedown', function(e) {\n    if (e.button !== 0) return;\n    startX = e.clientX; currentX = e.clientX; isDragging = true;\n    track.classList.remove('is-animating'); wrap.style.cursor = 'grabbing';\n  });\n  window.addEventListener('mousemove', function(e) {\n    if (!isDragging) return; currentX = e.clientX;\n    setTranslate(baseOffset + (currentX - startX), false);\n  });\n  window.addEventListener('mouseup', function() {\n    if (!isDragging) return; isDragging = false; wrap.style.cursor = '';\n    var delta = currentX - startX;\n    if (delta < -40) goTo(current + 1);\n    else if (delta > 40) goTo(current - 1);\n    else goTo(current);\n  });\n  window.addEventListener('resize', function() {\n    buildDots(); baseOffset = -(current * getCardW()); setTranslate(baseOffset, false);\n  });\n})();\n</script>",
