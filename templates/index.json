            "liquid": "{% comment %} ELIORA — Paiements + Garantie + Expert {% endcomment %}\n\n<link href=\"https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap\" rel=\"stylesheet\">\n\n<style>\n  .eli-trust {\n    font-family: 'Poppins', sans-serif;\n    color: #1A1A1A;\n    max-width: 640px;\n    margin: 0 auto;\n    padding: 8px 16px 32px;\n  }\n\n  /* ── ICÔNES PAIEMENT ── */\n  .eli-trust__payments {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    flex-wrap: wrap;\n    gap: 8px;\n    margin-bottom: 18px;\n  }\n  .eli-trust__payment {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    height: 30px;\n    padding: 4px 8px;\n    border: 1px solid rgba(26,26,26,0.12);\n    border-radius: 6px;\n    background: #FFFFFF;\n  }\n  .eli-trust__payment img {\n    height: 18px;\n    width: auto;\n    display: block;\n  }\n\n  /* ── BANDEAU GARANTIE / LIVRAISON ── */\n  .eli-trust__bar {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 0;\n    background: #FAF6F0;\n    border: 1px solid rgba(201,120,91,0.18);\n    border-radius: 14px;\n    padding: 18px 24px;\n    margin-bottom: 14px;\n  }\n  .eli-trust__bar-item {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    flex: 1;\n    justify-content: center;\n  }\n  .eli-trust__bar-item svg {\n    width: 20px; height: 20px;\n    stroke: #C9785B; fill: none;\n    stroke-width: 2; stroke-linecap: round; stroke-linejoin: round;\n    flex-shrink: 0;\n  }\n  .eli-trust__bar-text {\n    font-size: 15px;\n    font-weight: 700;\n    color: #C9785B;\n    white-space: nowrap;\n  }\n  .eli-trust__bar-sep {\n    width: 1px;\n    height: 28px;\n    background: rgba(201,120,91,0.25);\n    margin: 0 8px;\n    flex-shrink: 0;\n  }\n\n  /* ── CARTE EXPERT ── */\n  .eli-trust__expert {\n    display: flex;\n    align-items: flex-start;\n    gap: 18px;\n    background: #FAF6F0;\n    border: 1px solid rgba(201,120,91,0.18);\n    border-radius: 14px;\n    padding: 20px 22px;\n  }\n  .eli-trust__expert-photo {\n    width: 80px;\n    height: 80px;\n    min-width: 80px;\n    border-radius: 12px;\n    object-fit: cover;\n    display: block;\n  }\n  .eli-trust__expert-photo-placeholder {\n    width: 80px;\n    height: 80px;\n    min-width: 80px;\n    border-radius: 12px;\n    background: #EDE6DC;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    flex-shrink: 0;\n  }\n  .eli-trust__expert-photo-placeholder svg {\n    width: 36px; height: 36px;\n    stroke: #C9785B; fill: none;\n    stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round;\n  }\n  .eli-trust__expert-body { flex: 1; min-width: 0; }\n  .eli-trust__expert-top {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    margin-bottom: 6px;\n    flex-wrap: wrap;\n  }\n  .eli-trust__expert-name {\n    font-size: 16px;\n    font-weight: 700;\n    color: #1A1A1A;\n    margin: 0;\n    white-space: nowrap;\n  }\n  .eli-trust__expert-stars { display: inline-flex; gap: 2px; }\n  .eli-trust__expert-stars svg { width: 16px; height: 16px; fill: #C9785B; }\n  .eli-trust__expert-role {\n    font-size: 11px;\n    font-weight: 500;\n    color: #8A8178;\n    margin: 0 0 8px;\n    letter-spacing: 0.04em;\n  }\n  .eli-trust__expert-quote {\n    font-size: 14px;\n    font-style: italic;\n    font-weight: 400;\n    line-height: 1.6;\n    color: #4A4640;\n    margin: 0;\n  }\n\n  @media (max-width: 480px) {\n    .eli-trust__bar { padding: 14px 16px; }\n    .eli-trust__bar-text { font-size: 13px; }\n    .eli-trust__bar-item svg { width: 17px; height: 17px; }\n    .eli-trust__expert { gap: 14px; padding: 16px; }\n    .eli-trust__expert-photo,\n    .eli-trust__expert-photo-placeholder { width: 66px; height: 66px; min-width: 66px; }\n    .eli-trust__expert-name { font-size: 14.5px; }\n    .eli-trust__expert-quote { font-size: 13px; }\n  }\n</style>\n\n<div class=\"eli-trust\">\n\n  <!-- ICÔNES PAIEMENT — automatiques depuis ton store Shopify -->\n  <div class=\"eli-trust__payments\">\n    {% for type in shop.enabled_payment_types %}\n      <div class=\"eli-trust__payment\">\n        <img src=\"{{ type | payment_type_img_url }}\" alt=\"{{ type }}\">\n      </div>\n    {% endfor %}\n  </div>\n\n  <!-- BANDEAU GARANTIE + LIVRAISON -->\n  <div class=\"eli-trust__bar\">\n    <div class=\"eli-trust__bar-item\">\n      <svg viewBox=\"0 0 24 24\">\n        <polyline points=\"20 6 9 17 4 12\"/>\n      </svg>\n      <span class=\"eli-trust__bar-text\">Garantie 90 jours</span>\n    </div>\n    <span class=\"eli-trust__bar-sep\"></span>\n    <div class=\"eli-trust__bar-item\">\n      <svg viewBox=\"0 0 24 24\">\n        <rect x=\"1\" y=\"3\" width=\"15\" height=\"13\"/>\n        <path d=\"M16 8h4l3 3v5h-7V8z\"/>\n        <circle cx=\"5.5\" cy=\"18.5\" r=\"2.5\"/>\n        <circle cx=\"18.5\" cy=\"18.5\" r=\"2.5\"/>\n      </svg>\n      <span class=\"eli-trust__bar-text\">Livraison offerte</span>\n    </div>\n  </div>\n\n  <!-- CARTE EXPERT -->\n  <div class=\"eli-trust__expert\">\n\n    <div class=\"eli-trust__expert-photo-placeholder\">\n      <svg viewBox=\"0 0 24 24\">\n        <path d=\"M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2\"/>\n        <circle cx=\"12\" cy=\"7\" r=\"4\"/>\n      </svg>\n    </div>\n\n    <div class=\"eli-trust__expert-body\">\n      <div class=\"eli-trust__expert-top\">\n        <p class=\"eli-trust__expert-name\">Dr. Claire Fontaine</p>\n        <span class=\"eli-trust__expert-stars\">\n          <svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg>\n          <svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg>\n          <svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg>\n          <svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg>\n          <svg viewBox=\"0 0 24 24\"><polygon points=\"12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26\"/></svg>\n        </span>\n      </div>\n      <p class=\"eli-trust__expert-role\">Nutritionniste diplômée</p>\n      <p class=\"eli-trust__expert-quote\">« C'est l'une des rares solutions naturelles qui agit vraiment sur le confort digestif. Je la recommande à mes patientes ballonnées qui cherchent une approche douce et sans effets secondaires. »</p>\n    </div>\n\n  </div>\n\n</div>"
