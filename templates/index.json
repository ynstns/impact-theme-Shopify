        "liquid": "<link href=\"https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n<style>\n  .orya-presse {\n    background: transparent;\n    padding: 28px 0;\n    overflow: hidden;\n  }\n  .orya-presse__label {\n    text-align: center;\n    font-size: 13px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: #C9785B;\n    font-weight: 600;\n    margin-bottom: 22px;\n    font-family: 'Poppins', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n  }\n  .orya-presse__track-wrapper {\n    overflow: hidden;\n    position: relative;\n  }\n  .orya-presse__track {\n    display: flex;\n    align-items: center;\n    gap: 80px;\n    animation: orya-scroll 20s linear infinite;\n    width: max-content;\n  }\n  .orya-presse__logo {\n    height: 50px;\n    width: auto;\n    object-fit: contain;\n  }\n  @keyframes orya-scroll {\n    0% { transform: translateX(0); }\n    100% { transform: translateX(-50%); }\n  }\n  @media (max-width: 768px) {\n    .orya-presse__logo {\n      height: 40px;\n    }\n    .orya-presse__track {\n      gap: 50px;\n    }\n  }\n</style>\n<div class=\"orya-presse\">\n  <p class=\"orya-presse__label\">Vu dans</p>\n  <div class=\"orya-presse__track-wrapper\">\n    <div class=\"orya-presse__track\">\n      <img class=\"orya-presse__logo\" src=\"https://cdn.shopify.com/s/files/1/0991/5626/3286/files/Marie-Claire-logo.png?v=1777761700\" alt=\"Marie Claire\">\n      <img class=\"orya-presse__logo\" src=\"https://cdn.shopify.com/s/files/1/0991/5626/3286/files/images.png?v=1777761699\" alt=\"Elle\">\n      <img class=\"orya-presse__logo\" src=\"https://cdn.shopify.com/s/files/1/0991/5626/3286/files/VOGUE_revista_-_logo.png?v=1777761699\" alt=\"Vogue\">\n      <img class=\"orya-presse__logo\" src=\"https://cdn.shopify.com/s/files/1/0991/5626/3286/files/Logo_Le-Magazine-de-la-Sante.png?v=1777761699\" alt=\"Le Mag de la Santé\">\n      <img class=\"orya-presse__logo\" src=\"https://cdn.shopify.com/s/files/1/0991/5626/3286/files/Marie-Claire-logo.png?v=1777761700\" alt=\"Marie Claire\">\n      <img class=\"orya-presse__logo\" src=\"https://cdn.shopify.com/s/files/1/0991/5626/3286/files/images.png?v=1777761699\" alt=\"Elle\">\n      <img class=\"orya-presse__logo\" src=\"https://cdn.shopify.com/s/files/1/0991/5626/3286/files/VOGUE_revista_-_logo.png?v=1777761699\" alt=\"Vogue\">\n      <img class=\"orya-presse__logo\" src=\"https://cdn.shopify.com/s/files/1/0991/5626/3286/files/Logo_Le-Magazine-de-la-Sante.png?v=1777761699\" alt=\"Le Mag de la Santé\">\n    </div>\n  </div>\n</div>",
