   <span class=\"eliora-vudans__logo-wrap\">\n      <img class=\"eliora-vudans__logo\" src=\"https://cdn.shopify.com/s/files/1/0941/4010/5040/files/marie_claire_Orya.png?v=1782175768\" alt=\"Marie Claire\">\n    </span>\n    <span class=\"eliora-vudans__logo-wrap\">\n      <img class=\"eliora-vudans__logo\" src=\"https://cdn.shopify.com/s/files/1/0941/4010/5040/files/Mag_de_la_sante_Orya.png?v=1782175795\" alt=\"Le Mag de la Santé\">\n    </span>\n    <span class=\"eliora-vudans__logo-wrap\">\n      <img class=\"eliora-vudans__logo\" src=\"https://cdn.shopify.com/s/files/1/0941/4010/5040/files/Vogue_Orya.png?v=1782175786\" alt=\"Vogue\">\n    </span>\n    <span class=\"eliora-vudans__logo-wrap\">\n      <img class=\"eliora-vudans__logo\" src=\"https://cdn.shopify.com/s/files/1/0941/4010/5040/files/Elle_Orya.png?v=1782175775\" alt=\"ELLE\">\n    </span>\n  </div>\n\n</section>",
