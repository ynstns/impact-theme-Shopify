<script>
var EQ_TOTAL = 17;
var eqScoreQ3 = 2; // durée (1=court, 2=moyen, 3-4=long)
var eqScoreQ7 = 1; // stress (0=faible, 1=modéré, 2=élevé)

function eqProg(n) {
  var p = Math.round((n/EQ_TOTAL)*100);
  document.getElementById('eqBar').style.width = p+'%';
  var lbl = document.getElementById('eqPL');
  lbl.textContent = (n>0 && n<13) ? 'Question '+n+' / 12' : '';
}

function eqGo(n) {
  document.querySelectorAll('.eq-step').forEach(function(s){ s.classList.remove('active'); });
  var t = document.querySelector('[data-step="'+n+'"]');
  if(t){ t.classList.add('active'); eqProg(n); window.scrollTo({top:0,behavior:'smooth'}); }
  if(n===14){ eqLoader(); }
  if(n===17){ eqBuildResult(); }
}

function eqAge(el) {
  document.querySelectorAll('.eq-photo').forEach(function(c){ c.classList.remove('sel'); });
  el.classList.add('sel');
  setTimeout(function(){ eqGo(1); }, 350);
}

function eqS(el, step) {
  el.closest('.eq-opts').querySelectorAll('.eq-opt').forEach(function(o){ o.classList.remove('sel'); });
  el.classList.add('sel');
  // Capture scores
  var score = el.getAttribute('data-score');
  if(step===3 && score) eqScoreQ3 = parseInt(score);
  if(step===7 && score) eqScoreQ7 = parseInt(score);
  var b = document.getElementById('b'+step);
  if(b) b.classList.add('show');
  setTimeout(function(){ eqGo(step+1); }, 400);
}

function eqM(el, step) {
  el.classList.toggle('sel');
  var any = el.closest('.eq-opts').querySelectorAll('.eq-opt.sel').length > 0;
  var b = document.getElementById('b'+step);
  if(b){ any ? b.classList.add('show') : b.classList.remove('show'); }
}

function eqRestart() {
  document.querySelectorAll('.eq-step').forEach(function(s){ s.classList.remove('active'); });
  document.querySelectorAll('.eq-opt').forEach(function(o){ o.classList.remove('sel'); });
  document.querySelectorAll('.eq-photo').forEach(function(c){ c.classList.remove('sel'); });
  document.querySelectorAll('.eq-btn').forEach(function(b){ b.classList.remove('show'); });
  eqScoreQ3=2; eqScoreQ7=1;
  document.querySelector('[data-step="0"]').classList.add('active');
  eqProg(0); window.scrollTo({top:0,behavior:'smooth'});
}

/* CALCUL CURE ADAPTÉE */
function eqBuildResult() {
  var totalScore = eqScoreQ3 + eqScoreQ7;
  var cure, profil, meca, rev, badgeTxt;

  if(totalScore <= 1) {
    cure = '1 mois';
    profil = 'sensibilité digestive légère';
    meca = 'Gaz + Sensibilité';
    rev = 'Excellente';
    badgeTxt = '✓ Cure recommandée : 1 mois';
  } else if(totalScore <= 3) {
    cure = '3 mois';
    profil = 'fermentation intestinale modérée';
    meca = 'Gaz + Fermentation';
    rev = 'Très bonne';
    badgeTxt = '✓ Cure recommandée : 3 mois';
  } else {
    cure = '5 mois';
    profil = 'fermentation intestinale chronique';
    meca = 'Gaz + Fermentation\nchronique';
    rev = 'Bonne';
    badgeTxt = '✓ Cure recommandée : 5 mois';
  }

  document.getElementById('eqProfilName').innerHTML = 'Votre profil : <em>'+profil+'</em>';
  document.getElementById('eqMeca').textContent = meca;
  document.getElementById('eqRev').textContent = rev;
  document.getElementById('eqCure').textContent = cure;
  document.getElementById('eqCureBadge').textContent = badgeTxt;
}

function eqLoader() {
  var pct=0;
  var cf=document.getElementById('eqCF');
  var cp=document.getElementById('eqCP');
  var lt=document.getElementById('eqLT');
  // r=54, C = 2*PI*54 = 339.29
  var C=2*Math.PI*54;
  var ls=['eqL1','eqL2','eqL3','eqL4'];
  var si=0;
  cf.style.strokeDasharray=C;
  cf.style.strokeDashoffset=C;
  var iv=setInterval(function(){
    pct++;
    cf.style.strokeDashoffset=C-(pct/100)*C;
    cp.textContent=pct+'%';
    if(pct===25&&si<ls.length){document.getElementById(ls[si]).classList.add('done');si++;lt.textContent='Construction de votre profil digestif...';}
    if(pct===55&&si<ls.length){document.getElementById(ls[si]).classList.add('done');si++;}
    if(pct===78&&si<ls.length){document.getElementById(ls[si]).classList.add('done');si++;}
    if(pct===95&&si<ls.length){document.getElementById(ls[si]).classList.add('done');si++;}
    if(pct>=100){clearInterval(iv);setTimeout(function(){eqGo(15);},700);}
  },28);
}

eqProg(0);
</script>
