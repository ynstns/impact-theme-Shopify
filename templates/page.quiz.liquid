<script>
var EQ_TOTAL = 17;
function eqProg(n) {
  var p = Math.round((n / EQ_TOTAL) * 100);
  document.getElementById('eqBar').style.width = p + '%';
  var lbl = document.getElementById('eqProgLabel');
  if (n > 0 && n < 13) { lbl.textContent = 'Question ' + n + ' / 12'; }
  else { lbl.textContent = ''; }
}
function eqGo(n) {
  document.querySelectorAll('.eq-step').forEach(function(s){ s.classList.remove('active'); });
  var t = document.querySelector('[data-step="' + n + '"]');
  if (t) { t.classList.add('active'); eqProg(n); window.scrollTo({top:0,behavior:'smooth'}); }
  if (n === 14) { eqLoader(); }
}
function eqAge(el) {
  document.querySelectorAll('.eq-photo').forEach(function(c){ c.classList.remove('sel'); });
  el.classList.add('sel');
  setTimeout(function(){ eqGo(1); }, 350);
}
function eqS(el, step) {
  el.closest('.eq-opts').querySelectorAll('.eq-opt').forEach(function(o){ o.classList.remove('sel'); });
  el.classList.add('sel');
  var b = document.getElementById('b'+step);
  if (b) b.classList.add('show');
  setTimeout(function(){ eqGo(step+1); }, 400);
}
function eqM(el, step) {
  el.classList.toggle('sel');
  var any = el.closest('.eq-opts').querySelectorAll('.eq-opt.sel').length > 0;
  var b = document.getElementById('b'+step);
  if (b) { any ? b.classList.add('show') : b.classList.remove('show'); }
}
function eqRestart() {
  document.querySelectorAll('.eq-step').forEach(function(s){ s.classList.remove('active'); });
  document.querySelectorAll('.eq-opt').forEach(function(o){ o.classList.remove('sel'); });
  document.querySelectorAll('.eq-photo').forEach(function(c){ c.classList.remove('sel'); });
  document.querySelectorAll('.eq-btn').forEach(function(b){ b.classList.remove('show'); });
  document.querySelector('[data-step="0"]').classList.add('active');
  eqProg(0);
  window.scrollTo({top:0,behavior:'smooth'});
}
function eqLoader() {
  var pct = 0;
  var cf = document.getElementById('eqCF');
  var cp = document.getElementById('eqCP');
  var lt = document.getElementById('eqLT');
  var C = 2 * Math.PI * 44;
  var ls = ['eqL1','eqL2','eqL3','eqL4'];
  var titles = ['Préparation de votre cure...','Construction de votre profil digestif...','Construction de votre profil digestif...','Construction de votre profil digestif...'];
  var si = 0;
  cf.style.strokeDashoffset = C;
  var iv = setInterval(function(){
    pct++;
    cf.style.strokeDashoffset = C - (pct/100)*C;
    cp.textContent = pct + '%';
    if (pct===25 && si<ls.length){ document.getElementById(ls[si]).classList.add('done'); si++; lt.textContent=titles[1]; }
    if (pct===50 && si<ls.length){ document.getElementById(ls[si]).classList.add('done'); si++; }
    if (pct===75 && si<ls.length){ document.getElementById(ls[si]).classList.add('done'); si++; }
    if (pct===95 && si<ls.length){ document.getElementById(ls[si]).classList.add('done'); si++; }
    if (pct>=100){ clearInterval(iv); setTimeout(function(){ eqGo(15); },700); }
  }, 28);
}
eqProg(0);
</script>