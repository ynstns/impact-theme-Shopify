<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
.quiz-wrap { font-family: 'Poppins', sans-serif; background: #FAF6F0; color: #1A1A1A; min-height: 100vh; }
.progress-wrap { background: #EDE6DC; height: 4px; width: 100%; }
.progress-bar { height: 4px; background: #C9785B; transition: width 0.4s ease; width: 0%; }
.quiz-container { max-width: 600px; margin: 0 auto; padding: 32px 20px 60px; }
.step { display: none; }
.step.active { display: block; }
.step-label { font-size: 10.5px; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: #C9785B; margin-bottom: 12px; text-align: center; }
.step-hint { font-size: 11.5px; color: #8A8178; text-align: center; margin-bottom: 18px; font-style: italic; }
.step-title { font-size: clamp(22px, 5.5vw, 32px); font-weight: 400; line-height: 1.25; text-align: center; margin-bottom: 8px; color: #1A1A1A; letter-spacing: -0.02em; }
.step-title em { font-style: italic; color: #C9785B; font-weight: 400; }
.step-sub { text-align: center; font-size: 13.5px; color: #8A8178; margin-bottom: 32px; line-height: 1.6; }
.photo-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 28px; }
.photo-card { position: relative; border-radius: 16px; overflow: hidden; cursor: pointer; border: 2px solid transparent; transition: border-color 0.2s, transform 0.2s; aspect-ratio: 3/4; background: #EDE6DC; }
.photo-card:hover { border-color: rgba(201,120,91,0.5); transform: translateY(-2px); }
.photo-card.selected { border-color: #C9785B; }
.photo-card img { width: 100%; height: 100%; object-fit: cover; display: block; }
.photo-label { position: absolute; bottom: 0; left: 0; right: 0; padding: 36px 14px 14px; background: linear-gradient(to top, rgba(26,26,26,0.65), transparent); color: #FFFFFF; font-size: 14px; font-weight: 500; }
.cta-unlock { text-align: center; margin-top: 8px; }
.cta-unlock a { font-size: 13px; font-weight: 600; color: #C9785B; text-decoration: underline; text-underline-offset: 3px; cursor: pointer; }
.doctor-card { display: flex; align-items: center; gap: 14px; background: #FFFFFF; border: 1px solid rgba(26,26,26,0.08); border-radius: 14px; padding: 14px 18px; margin-top: 24px; }
.doctor-avatar { width: 48px; height: 48px; min-width: 48px; border-radius: 50%; overflow: hidden; flex-shrink: 0; }
.doctor-avatar img { width: 100%; height: 100%; object-fit: cover; object-position: center 20%; display: block; }
.doctor-label { font-size: 11px; color: #8A8178; margin-bottom: 2px; }
.doctor-name { font-size: 14px; font-weight: 700; color: #1A1A1A; }
.doctor-title { font-size: 12px; font-style: italic; color: #8A8178; }
.options-list { display: flex; flex-direction: column; gap: 12px; }
.option-card { background: #FFFFFF; border: 1.5px solid rgba(26,26,26,0.09); border-radius: 14px; padding: 16px 20px; cursor: pointer; display: flex; align-items: center; gap: 14px; transition: border-color 0.2s, background 0.2s; font-size: 15px; font-weight: 500; color: #1A1A1A; user-select: none; }
.option-card:hover { border-color: rgba(201,120,91,0.4); background: #FAF6F0; }
.option-card.selected { border-color: #C9785B; background: rgba(201,120,91,0.06); }
.option-icon { font-size: 22px; flex-shrink: 0; width: 36px; text-align: center; }
.option-check { margin-left: auto; width: 22px; height: 22px; border-radius: 50%; border: 2px solid rgba(26,26,26,0.2); flex-shrink: 0; display: flex; align-items: center; justify-content: center; transition: background 0.2s, border-color 0.2s; }
.option-card.selected .option-check { background: #C9785B; border-color: #C9785B; }
.option-card.selected .option-check::after { content: ''; width: 6px; height: 6px; border-radius: 50%; background: #FFFFFF; }
.option-check-multi { margin-left: auto; width: 22px; height: 22px; border-radius: 6px; border: 2px solid rgba(26,26,26,0.2); flex-shrink: 0; display: flex; align-items: center; justify-content: center; transition: background 0.2s, border-color 0.2s; }
.option-card.selected .option-check-multi { background: #C9785B; border-color: #C9785B; }
.option-card.selected .option-check-multi::after { content: ''; width: 10px; height: 6px; border-left: 2px solid #FFFFFF; border-bottom: 2px solid #FFFFFF; transform: rotate(-45deg) translateY(-1px); display: block; }
.btn-next { width: 100%; background: #1A1A1A; color: #FFFFFF; font-family: 'Poppins', sans-serif; font-size: 14px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; border: none; border-radius: 50px; padding: 18px 28px; cursor: pointer; margin-top: 24px; transition: background 0.2s, transform 0.2s; display: none; }
.btn-next.visible { display: block; }
.btn-next:hover { background: #C9785B; transform: translateY(-1px); }
.result-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(201,120,91,0.12); border-radius: 50px; padding: 8px 18px; font-size: 12px; font-weight: 600; color: #C9785B; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 20px; }
.result-badge svg { width: 14px; height: 14px; stroke: #C9785B; fill: none; stroke-width: 2; stroke-linecap: round; }
.result-box { background: #FFFFFF; border: 1px solid rgba(201,120,91,0.15); border-radius: 20px; padding: 24px 22px; margin-bottom: 16px; }
.result-box-title { font-size: 15px; font-weight: 700; color: #1A1A1A; margin-bottom: 8px; }
.result-box-text { font-size: 13.5px; line-height: 1.65; color: #4A4640; }
.result-box-text strong { color: #1A1A1A; font-weight: 600; }
.result-product { background: #FAF6F0; border: 1px solid rgba(201,120,91,0.2); border-radius: 20px; padding: 22px; display: flex; gap: 16px; align-items: center; margin-bottom: 20px; }
.result-product-img { width: 80px; height: 80px; min-width: 80px; border-radius: 12px; overflow: hidden; }
.result-product-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
.result-product-name { font-size: 15px; font-weight: 700; color: #1A1A1A; margin-bottom: 4px; }
.result-product-sub { font-size: 12px; color: #8A8178; margin-bottom: 8px; }
.result-stars { display: inline-flex; gap: 2px; margin-bottom: 4px; }
.result-stars svg { width: 13px; height: 13px; fill: #E0A23C; }
.result-price { font-size: 17px; font-weight: 700; color: #C9785B; }
.result-price-old { font-size: 13px; color: #8A8178; text-decoration: line-through; margin-left: 6px; }
.btn-cta { display: block; width: 100%; background: #C9785B; color: #FFFFFF; font-family: 'Poppins', sans-serif; font-size: 15px; font-weight: 700; text-align: center; text-decoration: none; padding: 18px 28px; border-radius: 50px; border: none; cursor: pointer; letter-spacing: 0.05em; transition: background 0.2s, transform 0.2s; box-shadow: 0 6px 20px rgba(201,120,91,0.30); }
.btn-cta:hover { background: #B56645; transform: translateY(-2px); }
.trust-line { display: flex; align-items: center; justify-content: center; gap: 16px; flex-wrap: wrap; margin-top: 16px; font-size: 12px; color: #8A8178; }
.trust-line span { display: flex; align-items: center; gap: 5px; }
.trust-line svg { width: 13px; height: 13px; stroke: #C9785B; fill: none; stroke-width: 2; stroke-linecap: round; }
@media (max-width: 480px) { .step-title { font-size: 20px; } .photo-card { border-radius: 12px; } .option-card { padding: 14px 16px; font-size: 14px; } }
</style>

